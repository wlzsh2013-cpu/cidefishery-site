---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';

const factors = [
  {
    icon: '/icons/fish-fry-feeding.svg',
    alt: 'Shell-free clean feeding icon for fish fry decapsulated brine shrimp eggs',
    title: '100% Shell-Free Clean Feeding',
    text: 'Eliminate the risk of lethal shell ingestion in sensitive fish larvae. Our premium decapsulated eggs remove the tedious labor of cyst separation entirely, preventing tank contamination and delivering direct, hassle-free nutrition to your nursery.',
  },
  {
    icon: '/icons/synchronized-hatching-windows.svg',
    alt: 'High-vitality live nauplii option icon for fish fry Artemia cyst feeding',
    title: 'High-Vitality Live Nauplii Options',
    text: 'Trigger natural hunting behaviors in predatory fish fry. For facilities operating internal hatching systems, our standard Artemia cysts offer highly synchronized release windows and rich lipid profiles to sustain rapid larval growth.',
  },
  {
    icon: '/icons/verified-batch-analysis.svg',
    alt: 'Tailored protocol matching icon for fish hatchery feed planning',
    title: 'Tailored Protocol Matching',
    text: 'Optimize your feed budget and growth curves. We align exact cyst grades, hatching rates, and nutritional densities with your targeted fish species, stocking density, and daily feeding frequency.',
  },
];

const recommendations = [
  {
    image: '/images/applications/decapsulated-brine-shrimp-eggs-fish-fry-recommendation-320x240.avif',
    alt: 'Decapsulated Brine Shrimp Eggs product format for fish fry feeding programs',
    title: 'Decapsulated Brine Shrimp Eggs',
    desc: 'Premium shell-removed eggs designed for direct feeding or specialized research trials, guaranteeing a pure, biosecure, and energy-dense diet with zero separation work.',
    href: '/products/decapsulated-eggs/',
    cta: 'View Decapsulated Eggs',
  },
  {
    image: '/images/applications/artemia-cysts-shrimp-recommendation-320x240.avif',
    alt: 'Artemia Cysts Standard Grade product format for fish fry live-feed production',
    title: 'Artemia Cysts (Standard Grade)',
    desc: 'The industry-standard choice for hatcheries managing internal live-feed production, offering dependable hatch yields and vibrant swimming prey for predatory fry.',
    href: '/products/artemia-cysts/',
    cta: 'View Artemia Cysts',
  },
];
---
<BaseLayout title="Artemia Cysts and Decapsulated Eggs for Fish Fry | CIDE FISHERY" description="Fish fry feeding page for Artemia cysts and decapsulated brine shrimp eggs, with product recommendations, packaging links and inquiry guidance." breadcrumbs={[{ name: 'Applications', url: '/applications/' }, { name: 'Fish Fry', url: '/applications/fish-fry/' }]} showBreadcrumb>
  <section class="section page-header bg-light"><div class="container product-hero"><div><span class="eyebrow">FISH FRY APPLICATION</span><h1>Premium Artemia Cysts &amp; Decapsulated Eggs for Fish Fry Feeding Programs</h1><p class="page-lead">Fragile marine and freshwater fish fry require highly digestible, pathogen-free nutritional support from their very first feed. CIDE FISHERY provides specialized larval diets tailored to your species' precise mouth gape and rearing systems. Whether you leverage live nauplii or shell-free options, our products guarantee excellent energy conversion to accelerate fry development and secure higher nursery survival rates.</p><div class="hero-ctas"><Button href="/contact/" variant="primary" size="lg">Discuss Fish Fry Supply</Button><Button href="/products/decapsulated-eggs/" variant="outline" size="lg">View Decapsulated Eggs</Button></div></div><img src="/images/products/decapsulated-eggs.jpg" alt="Decapsulated brine shrimp eggs for fish fry feeding programs" width="5440" height="3648" loading="eager" /></div></section>
  <section class="section fish-decision-section bg-light"><div class="container"><div class="section-head"><span class="eyebrow">FEEDING DECISION POINTS</span><h2>Selecting the Optimal Nutritional Path for Your Fish Hatchery</h2></div><div class="stage-grid">{factors.map((f, index)=>(<article class="stage-card"><img class="stage-icon" src={f.icon} alt={f.alt} width="58" height="58" loading="lazy" decoding="async" /><span class="step-num">{String(index + 1).padStart(2, '0')} /</span><h3>{f.title}</h3><p>{f.text}</p></article>))}</div></div></section>
  <section class="section bg-light fish-products-section"><div class="container"><div class="section-head"><span class="eyebrow">RECOMMENDED PRODUCTS</span><h2>Certified Early-Stage Feeds for Commercial Fish Nurseries</h2></div><div class="rec-grid">{recommendations.map((r)=>(<article class="rec-card"><img class="rec-product-img" src={r.image} alt={r.alt} width="320" height="240" loading="lazy" decoding="async" /><h3 class="rec-title">{r.title}</h3><p>{r.desc}</p><a href={r.href} class="btn btn-outline btn-sm">{r.cta}</a></article>))}</div></div></section>
  <section class="section bg-light fish-package-section"><div class="container package-band"><div><span class="eyebrow">PACKAGING AND HANDLING</span><h2>Custom Specifications and Reliable Supply Contract Planning</h2><p>Maintaining stable live-feed performance requires uncompromising climate and moisture control from factory to farm. CIDE FISHERY designs flexible packaging configurations—including high-barrier vacuum cans, moisture-proof foil bags, and heavy-duty drums—perfectly aligned with your monthly demand and regional cold-storage capabilities. Contact our technical team to finalize an optimized contract volume and logistics strategy for your upcoming spawning season.</p><div class="hero-ctas"><Button href="/trust/packaging/" variant="primary" size="lg">Packaging Options</Button><Button href="/products/artemia-cysts/" variant="outline" size="lg">Compare Artemia Cysts</Button></div></div><img src="/images/products/artemia-hydrated-eggs.jpg" alt="Hydrated brine shrimp eggs for hatchery feeding preparation" width="5440" height="3648" loading="lazy" /></div></section>
</BaseLayout>
<style>.page-header{padding:64px 0}.product-hero,.package-band{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}.product-hero img,.package-band img{width:100%;aspect-ratio:4/3;object-fit:cover;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-white)}.eyebrow{display:inline-block;color:var(--color-brand-blue);font-size:13px;font-weight:700;text-transform:uppercase;margin-bottom:10px}.page-lead{font-size:18px;opacity:.84;margin:16px 0 24px}.hero-ctas{display:flex;gap:16px;flex-wrap:wrap}.section-head{max-width:760px;margin-bottom:28px}.fish-decision-section{padding:120px 0}.fish-products-section{padding:40px 0 80px}.fish-package-section{padding:80px 0 120px}.fish-decision-section .section-head h2{margin-bottom:20px}.stage-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}.stage-card{border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);padding:32px;background:var(--color-white);text-align:left}.rec-card{display:flex;flex-direction:column;align-items:flex-start;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);padding:38px 30px;background:var(--color-white)}.stage-icon{display:block;width:58px;height:58px;margin:0 0 20px;object-fit:contain}.rec-product-img{display:block;width:160px;height:120px;margin:0;object-fit:contain;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-light-bg);padding:0}.step-num{display:block;color:var(--color-champagne-gold);font-weight:800}.stage-card h3{margin:8px 0;font-size:20px}.rec-title{display:block;margin:20px 0 8px!important}.stage-card p,.rec-card p{font-size:var(--fs-small);opacity:.8}.rec-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}.rec-card p{margin-bottom:16px;max-width:720px}.package-band{padding:68px 58px;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-white)}.package-band h2{margin-bottom:20px}.package-band p{margin-bottom:20px}.package-band img{height:100%;display:block;padding:0}@media(max-width:1024px){.product-hero,.package-band{grid-template-columns:1fr}.stage-grid{grid-template-columns:1fr 1fr}.rec-grid{grid-template-columns:1fr}}@media(max-width:767px){.stage-grid{grid-template-columns:1fr}.package-band{padding:20px}.fish-products-section{padding:40px 0 80px}.fish-package-section{padding:80px 0 120px}}</style>

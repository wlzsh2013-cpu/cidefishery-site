---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import Icon from '../../components/Icon.astro';

const factors = [
  { icon: 'fish-fry', title: 'Clean Feeding', text: 'Fish fry programs may prefer decapsulated eggs when shell separation creates extra work.' },
  { icon: 'artemia-cysts', title: 'Live Nauplii Option', text: 'Standard Artemia cysts remain useful where hatcheries operate their own hatching workflow.' },
  { icon: 'quality-control', title: 'Protocol Matching', text: 'Species, fry size and feeding frequency should guide product recommendation.' },
];

const recommendations = [
  { icon: 'fish-fry', title: 'Decapsulated Brine Shrimp Eggs', desc: 'Cleaner feeding without shell separation for fish fry and specialized trials.', href: '/products/decapsulated-eggs/', cta: 'View Decapsulated Eggs' },
  { icon: 'artemia-cysts', title: 'Artemia Cysts', desc: 'For hatcheries that hatch nauplii and manage feeding timing internally.', href: '/products/artemia-cysts/', cta: 'View Artemia Cysts' },
];
---
<BaseLayout title="Artemia Cysts and Decapsulated Eggs for Fish Fry | CIDE FISHERY" description="Fish fry feeding page for Artemia cysts and decapsulated brine shrimp eggs, with product recommendations, packaging links and inquiry guidance." breadcrumbs={[{ name: 'Applications', url: '/applications/' }, { name: 'Fish Fry', url: '/applications/fish-fry/' }]} showBreadcrumb>
  <section class="section page-header bg-light"><div class="container product-hero"><div><span class="eyebrow">Fish fry application</span><h1>Artemia Cysts for Fish Fry Feeding Programs</h1><p class="page-lead">Fish fry production can require flexible live-feed or clean-feed options depending on species, fry size and hatchery workflow. CIDE FISHERY supports both standard Artemia cysts and decapsulated brine shrimp eggs.</p><div class="hero-ctas"><Button href="/contact/" variant="primary" size="lg">Discuss Fish Fry Supply</Button><Button href="/products/decapsulated-eggs/" variant="outline" size="lg">View Decapsulated Eggs</Button></div></div><img src="/images/products/decapsulated-eggs.jpg" alt="Decapsulated brine shrimp eggs for fish fry feeding programs" width="5440" height="3648" loading="eager" /></div></section>
  <section class="section"><div class="container"><div class="section-head"><span class="eyebrow">Feeding decision points</span><h2>Match the Product to Fry Size and Feeding Workflow</h2></div><div class="factor-grid">{factors.map((f)=>(<article class="factor-card"><Icon name={f.icon} label={`${f.title} icon`} desc={f.text} className="factor-icon"/><h3>{f.title}</h3><p>{f.text}</p></article>))}</div></div></section>
  <section class="section bg-light"><div class="container"><div class="section-head"><span class="eyebrow">Recommended products</span><h2>Product Options for Fish Fry</h2></div><div class="rec-grid">{recommendations.map((r)=>(<article class="rec-card"><Icon name={r.icon} label={`${r.title} icon`} desc={r.desc} className="rec-icon"/><h3>{r.title}</h3><p>{r.desc}</p><a href={r.href} class="btn btn-outline btn-sm">{r.cta}</a></article>))}</div></div></section>
  <section class="section"><div class="container package-band"><div><span class="eyebrow">Packaging and handling</span><h2>Tell Us How the Feed Will Be Stored and Used</h2><p>Fish fry buyers should share species, fry stage, feeding frequency, monthly demand and packaging preference. This helps us discuss whether standard cysts or decapsulated eggs fit better.</p><div class="hero-ctas"><Button href="/trust/packaging/" variant="primary" size="lg">Packaging Options</Button><Button href="/products/artemia-cysts/" variant="outline" size="lg">Compare Artemia Cysts</Button></div></div><img src="/images/products/artemia-hydrated-eggs.jpg" alt="Hydrated brine shrimp eggs for hatchery feeding preparation" width="5440" height="3648" loading="lazy" /></div></section>
</BaseLayout>
<style>.page-header{padding:64px 0}.product-hero,.package-band{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}.product-hero img,.package-band img{width:100%;aspect-ratio:4/3;object-fit:cover;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-white)}.eyebrow{display:inline-block;color:var(--color-brand-blue);font-size:13px;font-weight:700;text-transform:uppercase;margin-bottom:10px}.page-lead{font-size:18px;opacity:.84;margin:16px 0 24px}.hero-ctas{display:flex;gap:16px;flex-wrap:wrap}.section-head{max-width:760px;margin-bottom:28px}.factor-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}.factor-card,.rec-card{border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);padding:24px;background:var(--color-white)}.factor-icon,.rec-icon{width:56px;height:56px;margin-bottom:12px}.factor-card p,.rec-card p{font-size:var(--fs-small);opacity:.8}.rec-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}.rec-card p{margin-bottom:16px}.package-band{padding:28px;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-light-bg)}@media(max-width:1024px){.product-hero,.package-band{grid-template-columns:1fr}.factor-grid,.rec-grid{grid-template-columns:1fr}}@media(max-width:767px){.package-band{padding:20px}}</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import Icon from '../../components/Icon.astro';

const factors = [
  { icon: 'crab-larvae', title: 'Sensitive Larval Stages', text: 'Crab and crustacean larvae often need careful feeding timing and stable live-feed preparation.' },
  { icon: 'artemia-cysts', title: 'Artemia-Based Feeding', text: 'Standard Artemia cysts support hatcheries that hatch nauplii for daily feeding routines.' },
  { icon: 'quality-control', title: 'Batch and Protocol Review', text: 'Discuss species, stage, feeding frequency and required batch information before ordering.' },
];

const recommendations = [
  { icon: 'artemia-cysts', title: 'Artemia Cysts', desc: 'Suitable for crab and crustacean larvae when the hatchery manages nauplii production.', href: '/products/artemia-cysts/', cta: 'View Artemia Cysts' },
  { icon: 'quality-control', title: 'Premium Artemia Cysts', desc: 'Useful for specialized hatcheries that want stronger batch communication.', href: '/products/premium-artemia-cysts/', cta: 'View Premium' },
];
---
<BaseLayout title="Artemia Cysts for Crab Larvae and Crustacean Hatcheries | CIDE FISHERY" description="Artemia cyst feeding solutions for crab larvae and crustacean hatcheries, with product recommendations, batch communication and packaging links." breadcrumbs={[{ name: 'Applications', url: '/applications/' }, { name: 'Crab Larvae', url: '/applications/crab-larvae/' }]} showBreadcrumb>
  <section class="section page-header bg-light"><div class="container product-hero"><div><span class="eyebrow">Crab larvae application</span><h1>Artemia Cysts for Crab and Crustacean Larvae</h1><p class="page-lead">Crab and crustacean hatcheries need careful feeding schedules, suitable live-feed preparation and consistent procurement planning. Artemia cysts can support larval feeding when hatchery operations control hatching and harvest timing.</p><div class="hero-ctas"><Button href="/contact/" variant="primary" size="lg">Discuss Crab Larvae Supply</Button><Button href="/products/artemia-cysts/" variant="outline" size="lg">View Artemia Cysts</Button></div></div><img src="/images/products/artemia-nauplii.jpg" alt="Artemia nauplii for crab and crustacean larvae feeding" width="5440" height="3648" loading="eager" /></div></section>
  <section class="section"><div class="container"><div class="section-head"><span class="eyebrow">Feeding considerations</span><h2>What Crustacean Hatcheries Should Clarify</h2></div><div class="factor-grid">{factors.map((f)=>(<article class="factor-card"><Icon name={f.icon} label={`${f.title} icon`} desc={f.text} className="factor-icon"/><h3>{f.title}</h3><p>{f.text}</p></article>))}</div></div></section>
  <section class="section bg-light"><div class="container"><div class="section-head"><span class="eyebrow">Recommended products</span><h2>Product Options for Crab Larvae Programs</h2></div><div class="rec-grid">{recommendations.map((r)=>(<article class="rec-card"><Icon name={r.icon} label={`${r.title} icon`} desc={r.desc} className="rec-icon"/><h3>{r.title}</h3><p>{r.desc}</p><a href={r.href} class="btn btn-outline btn-sm">{r.cta}</a></article>))}</div></div></section>
  <section class="section"><div class="container package-band"><div><span class="eyebrow">Packaging and support</span><h2>Plan Packaging, Storage and Batch Communication Together</h2><p>Share target species, hatchery stage, order volume and destination. Packaging and cold storage planning help protect procurement consistency for specialized hatchery programs.</p><div class="hero-ctas"><Button href="/trust/packaging/" variant="primary" size="lg">Packaging Options</Button><Button href="/trust/quality-control/" variant="outline" size="lg">Quality Control</Button></div></div><img src="/images/products/premium-artemia-blue-can.png" alt="Artemia cyst can packaging for crab larvae hatchery supply" width="403" height="486" loading="lazy" /></div></section>
</BaseLayout>
<style>.page-header{padding:64px 0}.product-hero,.package-band{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}.product-hero img,.package-band img{width:100%;aspect-ratio:4/3;object-fit:cover;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-white)}.package-band img{object-fit:contain;padding:24px}.eyebrow{display:inline-block;color:var(--color-brand-blue);font-size:13px;font-weight:700;text-transform:uppercase;margin-bottom:10px}.page-lead{font-size:18px;opacity:.84;margin:16px 0 24px}.hero-ctas{display:flex;gap:16px;flex-wrap:wrap}.section-head{max-width:760px;margin-bottom:28px}.factor-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}.factor-card,.rec-card{border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);padding:24px;background:var(--color-white)}.factor-icon,.rec-icon{width:56px;height:56px;margin-bottom:12px}.factor-card p,.rec-card p{font-size:var(--fs-small);opacity:.8}.rec-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}.rec-card p{margin-bottom:16px}.package-band{padding:28px;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-light-bg)}@media(max-width:1024px){.product-hero,.package-band{grid-template-columns:1fr}.factor-grid,.rec-grid{grid-template-columns:1fr}}@media(max-width:767px){.package-band{padding:20px}}</style>

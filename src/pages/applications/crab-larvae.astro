---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';

const factors = [
  {
    icon: '/icons/crab-crustacean-nurseries.svg',
    alt: 'Sensitive molting phase support icon for crab and crustacean larvae nurseries',
    title: 'Sensitive Molting Phase Support',
    text: 'Crab larvae are highly vulnerable during active molting intervals. Our premium nutrient-dense live nauplii provide the essential fatty acids and amino acids needed to accelerate shell thickening, lower grading stress, and suppress mortality rates.',
  },
  {
    icon: '/icons/synchronized-hatching-windows.svg',
    alt: 'Synchronized hatch routines icon for crab larvae Artemia cyst feeding windows',
    title: 'Synchronized Hatch Routines',
    text: 'Precision timing is everything in a crustacean nursery. Our Artemia cysts feature exceptional hatching synchronization, yielding uniform batches of highly active prey that trigger natural, aggressive feeding behaviors in young larvae.',
  },
  {
    icon: '/icons/rigorous-batch-transparency.svg',
    alt: 'Comprehensive batch traceability icon for crab larvae Artemia cyst sourcing',
    title: 'Comprehensive Batch Traceability',
    text: 'Secure complete biosecurity peace of mind for your larval investment. We supply fully documented pre-shipment analysis for every single contract lot, verifying exact hatching rates, particle sizes, and pathogen-free compliance.',
  },
];

const recommendations = [
  {
    image: '/images/applications/artemia-cysts-shrimp-recommendation-320x240.avif',
    alt: 'Artemia Cysts Standard Grade product format for commercial crab hatcheries',
    title: 'Artemia Cysts (Standard Grade)',
    desc: 'A reliable, highly cost-effective daily feed foundation for routine crustacean larval cycles, supporting steady nauplii yields and dependable nutritional baselines.',
    href: '/products/artemia-cysts/',
    cta: 'View Artemia Cysts',
  },
  {
    image: '/images/applications/premium-artemia-cysts-shrimp-recommendation-320x240.avif',
    alt: 'Premium Artemia Cysts product format for intensive crab larvae systems',
    title: 'Premium Artemia Cysts',
    desc: 'Hand-picked elite inventory boasting superior hatch efficiency and rapid synchronization, custom-engineered for intensive breeding facilities and sensitive larval systems.',
    href: '/products/premium-artemia-cysts/',
    cta: 'View Premium',
  },
];
---
<BaseLayout title="Artemia Cysts for Crab Larvae and Crustacean Hatcheries | CIDE FISHERY" description="Artemia cyst feeding solutions for crab larvae and crustacean hatcheries, with product recommendations, batch communication and packaging links." breadcrumbs={[{ name: 'Applications', url: '/applications/' }, { name: 'Crab Larvae', url: '/applications/crab-larvae/' }]} showBreadcrumb>
  <section class="section page-header bg-light"><div class="container product-hero"><div><span class="eyebrow">CRAB LARVAE APPLICATION</span><h1>Premium Artemia Cysts for Crab and Crustacean Larvae nurseries</h1><p class="page-lead">Rearing sensitive crab Zoea and Megalopa stages requires reliable, synchronized live nutrition to mitigate cannibalism and molting mortality. CIDE FISHERY supplies clean, high-yield Artemia cysts selected to deliver optimal lipid profiles and highly active nauplii. Align your live feed production seamlessly with volatile crustacean development windows to secure exceptional larval survival and uniform growth.</p><div class="hero-ctas"><Button href="/contact/" variant="primary" size="lg">Discuss Crab Larvae Supply</Button><Button href="/products/artemia-cysts/" variant="outline" size="lg">View Artemia Cysts</Button></div></div><img src="/images/applications/premium-artemia-cysts-coastal-nursery.avif" alt="Premium Artemia cysts and decapsulated eggs for coastal nurseries." width="1200" height="800" loading="eager" /></div></section>
  <section class="section crab-considerations-section bg-light"><div class="container"><div class="section-head"><span class="eyebrow">FEEDING CONSIDERATIONS</span><h2>Critical Benchmarks for High-Density Crustacean Larviculture</h2></div><div class="stage-grid">{factors.map((f, index)=>(<article class="stage-card"><img class="stage-icon" src={f.icon} alt={f.alt} width="58" height="58" loading="lazy" decoding="async" /><span class="step-num">{String(index + 1).padStart(2, '0')} /</span><h3>{f.title}</h3><p>{f.text}</p></article>))}</div></div></section>
  <section class="section bg-light crab-products-section"><div class="container"><div class="section-head"><span class="eyebrow">RECOMMENDED PRODUCTS</span><h2>Tailored Live Feed Grades for Commercial Crab Hatcheries</h2></div><div class="rec-grid">{recommendations.map((r)=>(<article class="rec-card"><img class="rec-product-img" src={r.image} alt={r.alt} width="320" height="240" loading="lazy" decoding="async" /><h3 class="rec-title">{r.title}</h3><p>{r.desc}</p><a href={r.href} class="btn btn-outline btn-sm">{r.cta}</a></article>))}</div></div></section>
  <section class="section bg-light crab-package-section"><div class="container package-band"><div><span class="eyebrow">PACKAGING AND SUPPORT</span><h2>Fully Integrated Packaging, Cold Storage &amp; Technical Alignment</h2><p>Uncompromising biological performance relies on robust barrier protection from our processing lines to your rearing tanks. CIDE FISHERY engineers flexible packaging systems—including moisture-proof multi-layer foil bags, fortified vacuum cans, and heavy-duty drums—perfectly configured to match your custom seasonal volumes and localized cold-chain setups. Contact our aquaculture specialists today to lock in a secure, continuous inventory supply contract for your next production season.</p><div class="hero-ctas"><Button href="/about/packaging/" variant="primary" size="lg">Packaging Options</Button><Button href="/about/quality-control/" variant="outline" size="lg">Quality Control</Button></div></div><img src="/images/applications/premium-brine-shrimp-eggs-can-production-area.avif" alt="Premium brine shrimp eggs can in production area." width="1011" height="749" loading="lazy" /></div></section>
</BaseLayout>
<style>.page-header{padding:64px 0}.product-hero,.package-band{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}.product-hero img,.package-band img{width:100%;aspect-ratio:4/3;object-fit:cover;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-white)}.eyebrow{display:inline-block;color:var(--color-brand-blue);font-size:13px;font-weight:700;text-transform:uppercase;margin-bottom:10px}.page-lead{font-size:18px;opacity:.84;margin:16px 0 24px}.hero-ctas{display:flex;gap:16px;flex-wrap:wrap}.section-head{max-width:760px;margin-bottom:28px}.crab-considerations-section{padding:120px 0}.crab-products-section{padding:40px 0 80px}.crab-package-section{padding:80px 0 120px}.crab-considerations-section .section-head h2{margin-bottom:20px}.stage-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}.stage-card{border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);padding:32px;background:var(--color-white);text-align:left}.rec-card{display:flex;flex-direction:column;align-items:flex-start;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);padding:30px 30px;background:var(--color-white)}.crab-products-section .rec-card{padding:30px!important}.stage-icon{display:block;width:58px;height:58px;margin:0 0 20px;object-fit:contain}.rec-product-img{display:block;width:160px;height:120px;margin:0;object-fit:contain;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-light-bg);padding:0}.step-num{display:block;color:var(--color-champagne-gold);font-weight:800}.stage-card h3{margin:8px 0;font-size:20px}.rec-title{display:block;margin:20px 0 8px!important}.stage-card p,.rec-card p{font-size:var(--fs-small);opacity:.8}.rec-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}.rec-card p{margin-bottom:16px;max-width:720px}.package-band{padding:68px 58px;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-white)}.package-band h2{margin-bottom:20px}.package-band p{margin-bottom:20px}.package-band img{height:100%;display:block;padding:0}@media(max-width:1024px){.product-hero,.package-band{grid-template-columns:1fr}.stage-grid{grid-template-columns:1fr 1fr}.rec-grid{grid-template-columns:1fr}}@media(max-width:767px){.stage-grid{grid-template-columns:1fr}.package-band{padding:20px}.crab-products-section{padding:40px 0 80px}.crab-package-section{padding:80px 0 120px}}</style>


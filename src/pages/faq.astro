---
import BaseLayout from "../layouts/BaseLayout.astro";

const faqs = [
  { q: "What are Artemia cysts used for?", a: "Artemia cysts (brine shrimp eggs) are primarily used as live feed for larval stages in shrimp hatcheries, fish fry programs, crab larvae hatcheries and other aquaculture operations worldwide." },
  { q: "Are there different grades of Artemia cysts available?", a: "Yes. We supply regular and premium Artemia cysts. Premium batches undergo additional consistency checks, batch-specific documentation, and careful handling for hatcheries requiring stable feeding performance." },
  { q: "What are the benefits of using premium Artemia cysts?", a: "Premium Artemia cysts offer more consistent hatching rates, detailed batch communication, and reliable nauplii output, which helps hatcheries maintain predictable feeding schedules and reduce larval mortality." },
  { q: "How long can Artemia cysts be stored?", a: "When stored in cool, dry conditions away from direct sunlight, Artemia cysts can maintain viability for extended periods. We provide temperature-controlled cold chain storage and share specific storage guidance with every order." },
  { q: "Can Artemia cysts be shipped to any country?", a: "We export to major aquaculture markets across Asia, the Middle East, South America, and Africa. Contact our export team for specific destination and logistics inquiries." },
  { q: "What is the cost of ordering Artemia cysts?", a: "Pricing depends on product grade, packaging format, order volume, and destination. Contact us with your requirements for a tailored quotation and supply proposal." },
];
---

<BaseLayout
  title="Artemia Cysts FAQ | Frequently Asked Questions | CIDE FISHERY"
  description="Frequently asked questions about Artemia cysts, brine shrimp eggs, packaging, storage, ordering and export supply from CIDE FISHERY."
  jsonLdType="FAQ"
  jsonLdData={{
    mainEntity: faqs.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  }}
  breadcrumbs={[{ name: "FAQ", url: "/faq/" }]}
  showBreadcrumb={false}
>
  <section class="custom-faq-page">
    <div class="faq-container">
      <div class="faq-hero">
        <p class="faq-eyebrow">Support Center</p>
        <h1>Frequently Asked Questions</h1>
        <p>
          Find quick answers about Artemia cyst products, hatchery supply, packaging options, and export logistics.
        </p>
      </div>

      <div class="faq-layout">
        <div class="faq-left">
          {faqs.map((faq, i) => (
            <div class={`faq-item${i === 0 ? " active" : ""}`}>
              <button class="faq-question" type="button">
                <span>{faq.q}</span>
                <i></i>
              </button>
              <div class="faq-answer">
                <p>{faq.a}</p>
              </div>
            </div>
          ))}
        </div>

        <aside class="faq-contact">
          <div class="contact-card dark">
            <span class="contact-label">Need quick answers?</span>
            <p class="contact-cta">Call us</p>
            <div class="contact-info">
              <small>Phone</small>
              <a href="tel:+8653188877777">+86 531 8887 7777</a>
            </div>
          </div>

          <div class="contact-card light">
            <span class="contact-label">Pre-sale inquiries?</span>
            <p class="contact-cta">Email us</p>
            <div class="contact-info">
              <small>E-mail</small>
              <a href="mailto:info@cidefishery.com">info@cidefishery.com</a>
            </div>
          </div>

          <div class="social-card">
            <span>Follow our updates</span>
            <div class="social-links">
              <a href="#" aria-label="Facebook">
                <svg viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
              <a href="#" aria-label="Instagram">
                <svg viewBox="0 0 24 24"><path d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 1 0 0-12.324zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405a1.441 1.441 0 1 1-2.882 0 1.441 1.441 0 0 1 2.882 0z"/></svg>
              </a>
              <a href="#" aria-label="YouTube">
                <svg viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              </a>
              <a href="#" aria-label="LinkedIn">
                <svg viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .custom-faq-page {
    background: #F5F8FC;
    padding: 90px 20px 110px;
    color: #0B1F33;
    font-family: "Noto Sans", system-ui, -apple-system, sans-serif;
  }

  .custom-faq-page p {
    margin-bottom: 0;
  }

  .custom-faq-page a {
    color: inherit;
  }

  .custom-faq-page h1 {
    font-family: "IBM Plex Sans", system-ui, -apple-system, sans-serif;
    margin: 0;
    line-height: 0.95;
  }

  .custom-faq-page h3 {
    font-family: "IBM Plex Sans", system-ui, -apple-system, sans-serif;
    margin: 0;
  }

  .faq-container {
    max-width: 1180px;
    margin: 0 auto;
  }

  .faq-hero {
    max-width: 760px;
    margin-bottom: 58px;
  }

  .faq-eyebrow {
    margin: 0 0 14px;
    color: #E6B36A;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .faq-hero h1 {
    font-size: clamp(44px, 7vw, 96px);
    letter-spacing: -0.06em;
    font-weight: 800;
    color: #1E5FA8;
  }

  .faq-hero p {
    max-width: 560px;
    margin: 24px 0 0;
    color: #102030;
    font-size: 18px;
    line-height: 1.7;
  }

  .faq-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: 48px;
    align-items: start;
  }

  .faq-left {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .faq-item {
    background: #fff;
    border-radius: 22px;
    overflow: hidden;
    box-shadow: 0 14px 38px rgba(11, 31, 51, 0.04);
  }

  .faq-question {
    width: 100%;
    border: 0;
    background: transparent;
    padding: 26px 28px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    cursor: pointer;
    text-align: left;
    color: #0B1F33;
    font-size: 20px;
    line-height: 1.35;
    font-weight: 700;
    font-family: "Noto Sans", system-ui, -apple-system, sans-serif;
  }

  .faq-question i {
    position: relative;
    flex: 0 0 34px;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: rgba(11, 31, 51, 0.06);
    transition: background 0.25s ease;
  }

  .faq-question i::before,
  .faq-question i::after {
    content: "";
    position: absolute;
    background: #0B1F33;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    border-radius: 2px;
  }

  .faq-question i::before {
    width: 14px;
    height: 2px;
  }

  .faq-question i::after {
    width: 2px;
    height: 14px;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease;
  }

  .faq-answer p {
    margin: 0;
    padding: 0 28px 28px;
    color: #102030;
    font-size: 16px;
    line-height: 1.8;
  }

  .faq-item.active .faq-answer {
    max-height: 260px;
  }

  .faq-item.active .faq-question i {
    background: #0B1F33;
  }

  .faq-item.active .faq-question i::before,
  .faq-item.active .faq-question i::after {
    background: #fff;
  }

  .faq-item.active .faq-question i::after {
    opacity: 0;
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .faq-contact {
    position: sticky;
    top: 30px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .contact-card,
  .social-card {
    border-radius: 28px;
    padding: 30px;
  }

  .contact-card a {
    color: inherit;
    text-decoration: none;
  }

  .contact-card.dark {
    background: #0B1F33;
    color: #fff;
  }

  .contact-card.light {
      background: #E9C187;
      color: #fff;
  }

  .contact-label,
  .social-card > span {
    display: block;
    margin-bottom: 10px;
    font-size: 14px;
    font-weight: 700;
    color: #E6B36A;
  }

  .contact-card.dark .contact-label {
    color: rgba(233, 193, 135, 0.8);
  }

    .contact-card.light .contact-label {
      color: #3A4B5B;
    }

    .contact-card.light .contact-cta {
      color: #0B1F33;
    }

  .contact-card h3 {
    margin-bottom: 28px;
    font-size: 32px;
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

    .contact-cta {
      padding-bottom: 28px;
      font-size: 32px;
      line-height: 1.05;
      letter-spacing: -0.04em;
      font-weight: 800;
      color: #E9C187;
      font-family: 'IBM Plex Sans', system-ui, -apple-system, sans-serif;
    }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .contact-info small {
    color: inherit;
    opacity: 0.65;
    font-size: 13px;
  }

  .contact-info a {
    color: inherit;
    text-decoration: none;
    font-size: 18px;
    font-weight: 800;
  }

  .contact-info a:hover {
    text-decoration: underline;
  }

  .social-card {
    background: #fff;
    }

  .social-card > span {
    color: #E6B36A;
  }

  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }

  .social-links a {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(11, 31, 51, 0.08);
    color: rgba(11, 31, 51, 0.55);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: background 0.25s ease, transform 0.25s ease;
  }

  .social-links a svg {
    width: 20px;
    height: 20px;
    fill: currentColor;
  }

  .social-links a:hover {
    transform: translateY(-3px);
    background: #E6B36A;
  }

  @media (max-width: 960px) {
    .custom-faq-page {
      padding: 70px 18px 80px;
    }

    .faq-layout {
      grid-template-columns: 1fr;
      gap: 34px;
    }

    .faq-contact {
      position: static;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
    }

    .social-card {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 640px) {
    .faq-contact {
      grid-template-columns: 1fr;
    }

    .social-card {
      grid-column: auto;
    }

    .faq-question {
      padding: 22px;
      font-size: 18px;
    }

    .faq-answer p {
      padding: 0 22px 24px;
    }
  }
</style>

<script>
  (function() {
    var handleClick = function() {
      var item = this.closest(".faq-item");
      var faqGroup = this.closest(".faq-left");

      faqGroup.querySelectorAll(".faq-item").forEach(function(faq) {
        if (faq !== item) faq.classList.remove("active");
      });

      item.classList.toggle("active");
    };

    document.querySelectorAll(".custom-faq-page .faq-question").forEach(function(button) {
      button.addEventListener("click", handleClick);
    });
  })();
</script>
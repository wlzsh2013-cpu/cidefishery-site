---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Icon from '../components/Icon.astro';

const stages = [
  { icon: 'quality-control', title: 'Early Larval Planning', desc: 'Confirm feeding protocol, water quality and hatchery schedule before choosing batch volume.' },
  { icon: 'artemia-cysts', title: 'Nauplii Feeding Window', desc: 'Harvested Artemia nauplii are commonly timed around larval feeding requirements.' },
  { icon: 'cold-storage', title: 'Post-Larvae Supply Continuity', desc: 'Recurring supply and storage planning help avoid interruptions during production cycles.' },
];

const recommendations = [
  { icon: 'artemia-cysts', title: 'Artemia Cysts', desc: 'Standard option for shrimp hatcheries that hatch nauplii according to their feeding schedule.', href: '/products/artemia-cysts/', cta: 'View Artemia Cysts' },
  { icon: 'quality-control', title: 'Premium Artemia Cysts', desc: 'For hatcheries that need stronger batch communication and consistency planning.', href: '/products/premium-artemia-cysts/', cta: 'View Premium' },
];
---
<BaseLayout title="Artemia Cysts for Shrimp Hatcheries | CIDE FISHERY" description="Artemia cyst supply for shrimp hatchery larval feeding, nauplii production, post-larvae planning, packaging and batch communication." breadcrumbs={[{ name: 'Applications', url: '/applications/' }, { name: 'Shrimp Hatchery', url: '/application-shrimp-hatchery/' }]} showBreadcrumb>
  <section class="section page-header bg-light"><div class="container product-hero"><div><span class="eyebrow">Shrimp hatchery application</span><h1>Artemia Cysts for Shrimp Hatcheries</h1><p class="page-lead">Shrimp hatcheries rely on dependable live-feed timing. Artemia cysts allow hatcheries to produce nauplii close to feeding time, while batch communication, storage and packaging planning help support continuous larval production.</p><div class="hero-ctas"><Button href="/contact/" variant="primary" size="lg">Discuss Hatchery Supply</Button><Button href="/products/artemia-cysts/" variant="outline" size="lg">View Artemia Cysts</Button></div></div><img src="/images/products/artemia-nauplii.jpg" alt="Artemia nauplii for shrimp hatchery larval feeding" width="5440" height="3648" loading="eager" /></div></section>
  <section class="section"><div class="container"><div class="section-head"><span class="eyebrow">Feeding program needs</span><h2>Key Considerations for Shrimp Larval Feeding</h2></div><div class="stage-grid">{stages.map((s) => (<article class="stage-card"><Icon name={s.icon} label={`${s.title} icon`} desc={s.desc} className="stage-icon" /><h3>{s.title}</h3><p>{s.desc}</p></article>))}</div></div></section>
  <section class="section bg-light"><div class="container"><div class="section-head"><span class="eyebrow">Recommended products</span><h2>Product Options for Shrimp Hatcheries</h2></div><div class="rec-grid">{recommendations.map((r) => (<article class="rec-card"><Icon name={r.icon} label={`${r.title} icon`} desc={r.desc} className="rec-icon" /><h3>{r.title}</h3><p>{r.desc}</p><a href={r.href} class="btn btn-outline btn-sm">{r.cta}</a></article>))}</div></div></section>
  <section class="section"><div class="container package-band"><div><span class="eyebrow">Packaging and quality links</span><h2>Plan Supply Around Packaging, Storage and QC</h2><p>For shrimp hatchery orders, include monthly volume, feeding stage, destination and preferred packaging. This helps us discuss product choice, packaging and cold storage support.</p><div class="hero-ctas"><Button href="/trust/packaging/" variant="primary" size="lg">Packaging Options</Button><Button href="/trust/quality-control/" variant="outline" size="lg">Quality Control</Button></div></div><img src="/images/products/premium-artemia-can.png" alt="Artemia cyst can packaging for shrimp hatchery supply" width="520" height="679" loading="lazy" /></div></section>
</BaseLayout>
<style>.page-header{padding:64px 0}.product-hero,.package-band{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}.product-hero img,.package-band img{width:100%;aspect-ratio:4/3;object-fit:cover;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-white)}.package-band img{object-fit:contain;padding:24px}.eyebrow{display:inline-block;color:var(--color-brand-blue);font-size:13px;font-weight:700;text-transform:uppercase;margin-bottom:10px}.page-lead{font-size:18px;opacity:.84;margin:16px 0 24px}.hero-ctas{display:flex;gap:16px;flex-wrap:wrap}.section-head{max-width:760px;margin-bottom:28px}.stage-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}.stage-card,.rec-card{border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);padding:24px;background:var(--color-white)}.stage-icon,.rec-icon{width:56px;height:56px;margin-bottom:12px}.stage-card p,.rec-card p{font-size:var(--fs-small);opacity:.8}.rec-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}.rec-card p{margin-bottom:16px}.package-band{padding:28px;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-light-bg)}@media(max-width:1024px){.product-hero,.package-band{grid-template-columns:1fr}.stage-grid{grid-template-columns:1fr}.rec-grid{grid-template-columns:1fr}}@media(max-width:767px){.package-band{padding:20px}}</style>

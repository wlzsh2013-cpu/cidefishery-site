---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';

const stages = [
  {
    icon: '/icons/early-larval-nutritional-security.svg',
    alt: 'Early larval nutritional security icon for shrimp Zoea and Mysis Artemia nauplii feeding',
    title: 'Early Larval Nutritional Security',
    desc: 'Protect fragile Zoea and Mysis development. Our high-vitality nauplii feature excellent fatty acid profiles and optimal particle sizes, ensuring ideal conversion rates and maximum survival before stepping up to higher tank densities.',
  },
  {
    icon: '/icons/synchronized-hatching-windows.svg',
    alt: 'Synchronized hatching windows icon for uniform Artemia cyst hatching in shrimp hatcheries',
    title: 'Synchronized Hatching Windows',
    desc: 'Secure flawless operational timing. Our Artemia cysts hatch uniformly within sharp commercial windows, allowing your technician teams to align live feed distribution perfectly with active larval feeding behaviors.',
  },
  {
    icon: '/icons/year-round-supply-continuity.svg',
    alt: 'Year-round supply continuity icon for shrimp hatchery Artemia cyst cold-chain allocation',
    title: 'Year-Round Supply Continuity',
    desc: 'Eliminate hatchery downtime during critical shrimp spawning seasons. Our robust cold-chain preservation and long-term contract allocation protect your facility from unexpected market inventory shortages.',
  },
];

const recommendations = [
  {
    image: '/images/applications/artemia-cysts-shrimp-recommendation-320x240.avif',
    alt: 'Artemia Cysts product format for commercial shrimp hatchery feeding programs',
    title: 'Artemia Cysts (Standard Grade)',
    desc: 'The robust daily foundation for commercial shrimp rearing, providing steady hatch rates and balanced biological value to uphold routine tank feeding programs.',
    href: '/products/artemia-cysts/',
    cta: 'View Artemia Cysts',
  },
  {
    image: '/images/applications/premium-artemia-cysts-shrimp-recommendation-320x240.avif',
    alt: 'Premium Artemia Cysts product format for high-density shrimp postlarvae systems',
    title: 'Premium Artemia Cysts',
    desc: 'Hand-selected elite batches with rapid synchronization and maximal nauplii density, tailored specifically for SPF nurseries and high-density postlarvae (PL) systems.',
    href: '/products/premium-artemia-cysts/',
    cta: 'View Premium',
  },
];
---
<BaseLayout title="Artemia Cysts for Shrimp Hatcheries | CIDE FISHERY" description="Artemia cyst supply for shrimp hatchery larval feeding, nauplii production, post-larvae planning, packaging and batch communication." breadcrumbs={[{ name: 'Applications', url: '/applications/' }, { name: 'Shrimp Hatchery', url: '/application-shrimp-hatchery/' }]} showBreadcrumb>
  <section class="section page-header bg-light"><div class="container product-hero"><div><span class="eyebrow">SHRIMP HATCHERY APPLICATION</span><h1>Premium Artemia Cysts for Industrial Shrimp Hatcheries</h1><p class="page-lead">High-efficiency shrimp larviculture demands highly predictable and nutrient-dense live feed. CIDE FISHERY supplies premium-grade Artemia cysts engineered to yield heavy, synchronized nauplii hatches. Our batches deliver the precise lipid and protein profiles necessary to accelerate growth, enhance molting success, and maintain non-stop production cycles in your rearing tanks.</p><div class="hero-ctas"><Button href="/contact/" variant="primary" size="lg">Discuss Hatchery Supply</Button><Button href="/products/artemia-cysts/" variant="outline" size="lg">View Artemia Cysts</Button></div></div><img src="/images/applications/artemia-cysts-shrimp-hatchery-coast.avif" alt="Artemia cysts for coastal shrimp hatchery applications" width="1536" height="1024" loading="eager" /></div></section>
  <section class="section shrimp-nutrition-section bg-light"><div class="container"><div class="section-head"><span class="eyebrow">FEEDING PROGRAM NEEDS</span><h2>Optimizing Postlarvae Survival with Synchronized Live Nutrition</h2></div><div class="stage-grid">{stages.map((s, index) => (<article class="stage-card"><img class="stage-icon" src={s.icon} alt={s.alt} width="58" height="58" loading="lazy" decoding="async" /><span class="step-num">{String(index + 1).padStart(2, '0')} /</span><h3>{s.title}</h3><p>{s.desc}</p></article>))}</div></div></section>
  <section class="section bg-light shrimp-products-section"><div class="container"><div class="section-head"><span class="eyebrow">RECOMMENDED PRODUCTS</span><h2>Verified Live Feed Grades for Commercial Shrimp Systems</h2></div><div class="rec-grid">{recommendations.map((r) => (<article class="rec-card"><img class="rec-product-img" src={r.image} alt={r.alt} width="320" height="240" loading="lazy" decoding="async" /><h3 class="rec-title">{r.title}</h3><p>{r.desc}</p><a href={r.href} class="btn btn-outline btn-sm">{r.cta}</a></article>))}</div></div></section>
  <section class="section bg-light shrimp-package-section"><div class="container package-band"><div><span class="eyebrow">PACKAGING AND QUALITY LINKS</span><h2>Sealed Containment &amp; Biosecurity for Large-Scale Cargo</h2><p>Biological viability hinges entirely on professional barrier control. For high-volume shrimp facility contracts, we provide fully customized packaging specifications including hermetically sealed vacuum cans, multi-layer foil bags, and heavy-duty drums. Every shipment is backed by verified laboratory certificates, localized trade documentation, and comprehensive cold-chain logistics to secure fresh arrival at your port.</p><div class="hero-ctas"><Button href="/about/packaging/" variant="primary" size="lg">Packaging Options</Button><Button href="/about/quality-control/" variant="outline" size="lg">Quality Control</Button></div></div><img src="/images/applications/artemia-cysts-hatching-instructions-bucket.avif" alt="Artemia cysts bucket with hatching instructions" width="1536" height="1024" loading="lazy" /></div></section>
</BaseLayout>
<style>.page-header{padding:64px 0}.product-hero,.package-band{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}.product-hero img,.package-band img{width:100%;aspect-ratio:4/3;object-fit:cover;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-white)}.eyebrow{display:inline-block;color:var(--color-brand-blue);font-size:13px;font-weight:700;text-transform:uppercase;margin-bottom:10px}.page-lead{font-size:18px;opacity:.84;margin:16px 0 24px}.hero-ctas{display:flex;gap:16px;flex-wrap:wrap}.section-head{max-width:760px;margin-bottom:28px}.shrimp-nutrition-section{padding:120px 0}.shrimp-products-section{padding:40px 0 80px}.shrimp-package-section{padding:80px 0 120px}.shrimp-nutrition-section .section-head h2{margin-bottom:20px}.stage-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}.stage-card{border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);padding:32px;background:var(--color-white);text-align:left}.rec-card{display:flex;flex-direction:column;align-items:flex-start;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);padding:30px 30px;background:var(--color-white)}.stage-icon{display:block;width:58px;height:58px;margin:0 0 20px;object-fit:contain}.rec-product-img{display:block;width:160px;height:120px;margin:0;object-fit:contain;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-light-bg);padding:0}.step-num{display:block;color:var(--color-champagne-gold);font-weight:800}.stage-card h3{margin:8px 0;font-size:20px}.rec-title{display:block;margin:20px 0 8px!important}.stage-card p,.rec-card p{font-size:var(--fs-small);opacity:.8}.rec-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}.rec-card p{margin-bottom:16px;max-width:720px}.package-band{padding:68px 58px;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-white)}.package-band h2{margin-bottom:20px}.package-band p{margin-bottom:20px}.package-band img{height:100%;display:block;padding:0}@media(max-width:1024px){.product-hero,.package-band{grid-template-columns:1fr}.stage-grid{grid-template-columns:1fr 1fr}.rec-grid{grid-template-columns:1fr}}@media(max-width:767px){.stage-grid{grid-template-columns:1fr}.package-band{padding:20px}.shrimp-products-section{padding:40px 0 80px}.shrimp-package-section{padding:80px 0 120px}}</style>


---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CTASection from "../../../components/CTASection.astro";

const post = {
  title: "Client Visit: Vietnam Shrimp Hatchery Delegation Tours Facility",
  date: "2026-06-08",
  category: "Customer Visits",
  excerpt: "A delegation from three major Vietnamese shrimp hatcheries visited our Wenchang processing facility.",
  author: "CIDE FISHERY Team",
  cover: "/images/blog/default-cover.webp",
  tags: ["Client Visit", "Vietnam", "Shrimp Hatchery", "Facility Tour"],
};

const relatedPosts = [
  { title: "Welcome Visit from Indonesian Aquaculture Importers", slug: "indonesian-importers-visit" },
  { title: "Thailand Shrimp Farm Group Completes Technical Visit", slug: "thailand-shrimp-farm-visit" },
];
---

<BaseLayout
  title={post.title + " | CIDE FISHERY News"}
  description={post.excerpt}
  ogType="article"
  article={{ publishedTime: post.date }}
  jsonLdType="Article"
  jsonLdData={{ headline: post.title, datePublished: post.date }}
  breadcrumbs={[{ name: "News", url: "/news/" }, { name: "Customer Visits", url: "/news/customer-visits/" }, { name: post.title, url: "/news/customer-visits/vietnam-hatchery-delegation-visit/" }]}
  showBreadcrumb
>
  <div class="article-page-wrapper">
    <div class="article-layout">
      <article class="article-shell">
        <header class="article-header">
          <p class="article-kicker">{post.category}</p>
          <h1>{post.title}</h1>
          <p class="article-description">{post.excerpt}</p>
          <div class="article-meta">
            <time datetime={post.date}>Published {post.date}</time>
          </div>
          <div class="article-tags">
            <span>Client Visit</span>
            <span>Vietnam</span>
            <span>Shrimp Hatchery</span>
            <span>Facility Tour</span>
          </div>
        </header>

        <div class="share-bar">
          <span class="share-label">Share</span>
          <a href={"https://www.linkedin.com/shareArticle?mini=true&url=" + encodeURIComponent("https://cidefishery.com/news/customer-visits/vietnam-hatchery-delegation-visit/") + "&title=" + encodeURIComponent(post.title)} target="_blank" rel="noopener" aria-label="Share on LinkedIn" class="share-btn">
            <svg viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href={"https://www.facebook.com/sharer/sharer.php?u=" + encodeURIComponent("https://cidefishery.com/news/customer-visits/vietnam-hatchery-delegation-visit/")} target="_blank" rel="noopener" aria-label="Share on Facebook" class="share-btn">
            <svg viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href={"https://twitter.com/intent/tweet?url=" + encodeURIComponent("https://cidefishery.com/news/customer-visits/vietnam-hatchery-delegation-visit/") + "&text=" + encodeURIComponent(post.title)} target="_blank" rel="noopener" aria-label="Share on Twitter" class="share-btn">
            <svg viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href={"https://www.reddit.com/submit?url=" + encodeURIComponent("https://cidefishery.com/news/customer-visits/vietnam-hatchery-delegation-visit/") + "&title=" + encodeURIComponent(post.title)} target="_blank" rel="noopener" aria-label="Share on Reddit" class="share-btn">
            <svg viewBox="0 0 24 24"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.6 12.4a1.81 1.81 0 0 1-1.272.528c-.465 0-.884-.18-1.203-.496a5.89 5.89 0 0 0-3.019-1.388l.614-2.886 2.002.424a1.39 1.39 0 1 1 .233.825l-2.26-.478-.683 3.191a5.93 5.93 0 0 0-2.9 1.38 1.79 1.79 0 0 0-1.198-.485 1.81 1.81 0 0 0-1.275 3.088 1.81 1.81 0 0 0 2.425-.112 5.88 5.88 0 0 0 3.657 1.596c.086.005.172.008.259.008.085 0 .17-.003.254-.008a5.88 5.88 0 0 0 3.658-1.596 1.81 1.81 0 0 0 2.425.112 1.81 1.81 0 0 0 .002-2.56zM9.82 15.07a.932.932 0 1 1 0-1.864.932.932 0 0 1 0 1.864zm4.36 0a.932.932 0 1 1 0-1.864.932.932 0 0 1 0 1.864z"/></svg>
          </a>
          <a href={"https://api.whatsapp.com/send?text=" + encodeURIComponent(post.title + " " + "https://cidefishery.com/news/customer-visits/vietnam-hatchery-delegation-visit/")} target="_blank" rel="noopener" aria-label="Share on WhatsApp" class="share-btn share-btn-wa">
            <svg viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
          </a>
        </div>

        <div class="article-content">
          <h2 id="section-overview">Overview</h2>
          <p>A delegation from three major Vietnamese shrimp hatcheries visited our Wenchang processing facility.</p>
          <h2 id="section-details">Facility Tour and Demonstrations</h2>
          <p>Representatives from three leading Vietnamese shrimp hatchery groups spent a full day at our Wenchang facility. The visit included a comprehensive tour of our processing lines, quality control laboratory, cold storage facilities, and packaging center. Live hatching demonstrations were conducted using multiple Artemia cyst batches, allowing the delegation to observe hatch rate consistency and nauplii quality firsthand.</p>
          <h2 id="section-outlook">Strengthening Supply Partnerships</h2>
          <p>The visit concluded with productive technical discussions about customized supply programs tailored to Vietnamese hatchery requirements. Topics covered included optimal packaging formats for tropical climate shipping, cold chain protocols for Southeast Asian routes, and batch reservation systems for peak production seasons. Multiple supply agreements are now in negotiation following this successful engagement.</p>
        </div>
      </article>

      <aside class="article-sidebar">
        <section>
          <h2>News Categories</h2>
          <div class="sidebar-cats">
            <a href="/news/company-news/" class="sidebar-cat-link"><span class="sidebar-cat-dot"></span><span>Company News</span></a>
            <a href="/news/exhibitions/" class="sidebar-cat-link"><span class="sidebar-cat-dot"></span><span>Exhibitions</span></a>
            <a href="/news/customer-visits/" class="sidebar-cat-link is-active"><span class="sidebar-cat-dot"></span><span>Customer Visits</span></a>
          </div>
        </section>

        <section>
          <h2>Related News</h2>
          <ol class="sidebar-posts">
            {relatedPosts.map((p, i) => (
              <li>
                <span class="sidebar-post-num">{String(i + 1).padStart(2, "0")}</span>
                <a href={"/news/customer-visits/" + p.slug + "/"}>{p.title}</a>
              </li>
            ))}
          </ol>
        </section>

        <section>
          <h2>Quick Links</h2>
          <nav>
            <a href="/products/" class="sidebar-cat-link"><span class="sidebar-cat-dot"></span><span>Products</span></a>
            <a href="/about/" class="sidebar-cat-link"><span class="sidebar-cat-dot"></span><span>About Us</span></a>
            <a href="/contact/" class="sidebar-cat-link"><span class="sidebar-cat-dot"></span><span>Contact</span></a>
          </nav>
        </section>
      </aside>
    </div>

    <CTASection
      title="Interested in Learning More?"
      description="Contact our team for additional information about our products, facility, or upcoming exhibitions."
      ctaText="Get in Touch"
      ctaHref="/contact/"
    />
  </div>
</BaseLayout>

<style is:global>
  .article-page-wrapper { background: #F5F8FC; }
  .article-layout { display: grid; grid-template-columns: 1fr 280px; gap: 48px; width: 90%; margin: 0 auto; padding: 60px 0 80px; max-width: 1320px; align-items: start; }
  .article-shell { background: #fff; border-radius: 20px; padding: 48px; box-shadow: 0 2px 8px rgba(11, 31, 51, 0.03); }
  .article-header { margin-bottom: 28px; }
  .article-kicker { display: inline-flex; margin: 0 0 14px; padding: 5px 14px; border-radius: 999px; background: rgba(230, 179, 106, 0.15); color: #C18B3A; font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
  .article-header h1 { margin: 0 0 16px; font-size: clamp(28px, 4vw, 40px); font-weight: 800; line-height: 1.2; color: #0B1F33; font-family: "IBM Plex Sans", system-ui, -apple-system, sans-serif; letter-spacing: -0.03em; }
  .article-description { margin: 0 0 20px; font-size: 17px; line-height: 1.65; color: rgba(16, 32, 48, 0.65); }
  .article-meta { display: flex; align-items: center; gap: 8px; margin-bottom: 16px; font-size: 13px; color: rgba(16, 32, 48, 0.4); }
  .article-meta span { color: rgba(16, 32, 48, 0.2); }
  .article-tags { display: flex; flex-wrap: wrap; gap: 8px; }
  .article-tags span { padding: 4px 12px; border-radius: 999px; background: rgba(30, 95, 168, 0.08); color: #1E5FA8; font-size: 12px; font-weight: 700; }

  .share-bar { display: flex; align-items: center; gap: 8px; margin-bottom: 32px; padding: 14px 18px; background: #F5F8FC; border: 1px solid rgba(11, 31, 51, 0.06); border-radius: 14px; }
  .share-label { font-size: 13px; font-weight: 700; color: rgba(16, 32, 48, 0.45); letter-spacing: 0.06em; text-transform: uppercase; margin-right: 4px; flex-shrink: 0; }
  .share-btn { display: flex; align-items: center; justify-content: center; width: 38px; height: 38px; border-radius: 50%; background: rgba(11, 31, 51, 0.05); color: rgba(11, 31, 51, 0.55); transition: all 0.2s ease; text-decoration: none; }
  .share-btn svg { width: 17px; height: 17px; fill: currentColor; }
  .share-btn:hover { background: #0B1F33; color: #fff; transform: translateY(-2px); }
  .share-btn-wa:hover { background: #25D366; }

  .article-content { font-size: 16px; line-height: 1.8; color: rgba(16, 32, 48, 0.75); }
  .article-content h2 { margin: 40px 0 16px; font-size: 24px; font-weight: 800; color: #0B1F33; font-family: "IBM Plex Sans", system-ui, -apple-system, sans-serif; }
  .article-content p { margin: 0 0 16px; }

  .article-sidebar { position: sticky; top: 100px; align-self: start; display: flex; flex-direction: column; gap: 24px; }
  .article-sidebar section { padding: 24px; background: #fff; border-radius: 16px; box-shadow: 0 2px 8px rgba(11, 31, 51, 0.03); }
  .article-sidebar h2 { margin: 0 0 16px; font-size: 16px; font-weight: 800; letter-spacing: 0.04em; color: #0B1F33; font-family: "IBM Plex Sans", system-ui, -apple-system, sans-serif; }
  .article-sidebar nav { display: flex; flex-direction: column; gap: 2px; }
  .sidebar-cats { display: flex; flex-direction: column; gap: 2px; }
  .sidebar-cat-link { display: flex; align-items: center; gap: 8px; padding: 7px 10px; border-radius: 999px; font-size: 13px; font-weight: 700; color: rgba(16, 32, 48, 0.6); text-decoration: none; transition: all 0.2s ease; }
  .sidebar-cat-link:hover { background: rgba(30, 95, 168, 0.06); color: #1E5FA8; }
  .sidebar-cat-link.is-active { background: rgba(30, 95, 168, 0.08); color: #1E5FA8; }
  .sidebar-cat-dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(30, 95, 168, 0.2); flex-shrink: 0; }

  .sidebar-posts { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 6px; }
  .sidebar-posts li { display: grid; grid-template-columns: 1.5rem 1fr; gap: 8px; font-size: 13px; line-height: 1.5; }
  .sidebar-post-num { font-size: 11px; font-weight: 800; color: #1E5FA8; }
  .sidebar-posts a { color: rgba(16, 32, 48, 0.65); text-decoration: none; transition: color 0.2s ease; }
  .sidebar-posts a:hover { color: #1E5FA8; }

  @media (max-width: 1024px) {
    .article-layout { grid-template-columns: 1fr; gap: 32px; padding: 48px 18px; }
    .article-sidebar { position: static; }
  }
  @media (max-width: 640px) {
    .article-shell { padding: 28px; }
    .share-bar { flex-wrap: wrap; justify-content: center; gap: 6px; padding: 12px 14px; }
    .share-label { width: 100%; text-align: center; margin-bottom: 4px; }
    .share-btn { width: 36px; height: 36px; }
    .share-btn svg { width: 16px; height: 16px; }
    .article-content { font-size: 15px; }
    .article-content h2 { margin-top: 36px; font-size: 22px; }
  }
</style>
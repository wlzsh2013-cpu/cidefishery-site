---

import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
---
<BaseLayout
  title="Page Not Found | CIDE FISHERY"
  description="The page you are looking for does not exist. Browse our Artemia cyst products or contact us for supply information."
  noindex
>
  <section class="section" style="min-height:60vh;display:flex;align-items:center;text-align:center;">
    <div class="container" style="max-width:600px;">
      <h1 style="font-size:72px;color:var(--color-champagne-gold);">404</h1>
      <h2>Page Not Found</h2>
      <p style="margin:16px 0 32px;">The page you are looking for may have been moved or is no longer available. Please use the links below to find what you need.</p>
      <div class="notfound-ctas">
        <Button href="/" variant="primary" size="lg">Back to Home</Button>
        <Button href="/products/" variant="outline" size="lg">View Products</Button>
        <Button href="/contact/" variant="text" size="lg">Contact Us</Button>
      </div>
    </div>
  </section>
</BaseLayout>
<style>
  .notfound-ctas { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import CTASection from '../../components/CTASection.astro';

const benefits = [
  { icon: '/icons/verified-batch-analysis.svg', alt: 'Verified batch analysis icon for premium Artemia cysts', title: 'Verified Batch Analysis', text: 'Gain complete transparency with independent batch-specific data sheets covering hatch rate, synchronization, and nutritional profiles before procurement.' },
  { icon: '/icons/strict-cold-chain-integrity.svg', alt: 'Strict cold-chain integrity icon for premium Artemia cyst storage', title: 'Strict Cold-Chain Integrity', text: 'Every premium batch is preserved under optimal, climate-controlled conditions to prevent cellular degradation and secure long-term performance.' },
  { icon: '/icons/high-density-hatchery-fit.svg', alt: 'High-density hatchery fit icon for premium Artemia cyst feeding programs', title: 'High-Density Hatchery Fit', text: 'Optimized for rigorous commercial systems that require maximum postlarvae (PL) survival rates, robust vitality, and uniform growth cycles.' },
  { icon: '/icons/heavy-duty-export-packing.svg', alt: 'Heavy-duty export packing icon for premium Artemia cyst shipments', title: 'Heavy-Duty Export Packing', text: 'Packed in industrial vacuum-sealed cans, shock-resistant cartons, and moisture-barrier drums designed to withstand long-distance maritime transit.' },
];

const specs = [
  { label: 'Product Classification', value: 'Premium Selected Artemia Cysts (High-Hatchability Batches)' },
  { label: 'Target Operations', value: 'SPF shrimp hatcheries, marine fish fry programs, and elite crustacean nurseries' },
  { label: 'Core Focus', value: 'Guaranteed batch synchronization, uniform sizing, and biosecurity peace of mind' },
  { label: 'Packaging Standard', value: 'Reinforced vacuum cans, heavy-duty outer master cartons, and custom private labeling' },
  { label: 'Technical Resources', value: 'Full traceability logs, cold storage setup assistance, and batch certificates' },
];
---

<BaseLayout
  title="Premium Artemia Cysts for Industrial Hatcheries & Breeding Programs | CIDE FISHERY"
  description="Premium Artemia cysts for industrial hatcheries and breeding programs requiring hatching synchronization, batch consistency, cold-chain control and export packaging."
  ogImage="/images/products/premium-artemia-cysts-can.avif"
  jsonLdType="Product"
  jsonLdData={{ name: 'Premium Artemia Cysts', description: 'High-synchronization premium Artemia cysts for industrial hatcheries and breeding programs', category: 'Aquaculture Supplies' }}
  breadcrumbs={[{ name: 'Products', url: '/products/' }, { name: 'Premium Artemia Cysts', url: '/products/premium-artemia-cysts/' }]}
  showBreadcrumb
>
  <section class="section hero-section bg-light">
    <div class="container hero-grid">
      <div>
        <span class="eyebrow">HIGH-SYNCHRONIZATION &amp; PREMIUM GRADE</span>
        <h1>Premium Artemia Cysts for Industrial Hatcheries &amp; Breeding Programs</h1>
        <p class="page-lead">Engineered for high-density aquaculture systems, our premium-grade Artemia cysts deliver exceptional hatching synchronization and maximum live nauplii counts. We provide fully documented batch consistency and specialized technical support to ensure stable, reliable nutrition for critical early-stage larval rearing.</p>
        <div class="hero-ctas">
          <Button href="/contact/" variant="primary" size="lg">Request Premium Batch Details</Button>
          <Button href="/about/quality-control/" variant="outline" size="lg">Quality Control Standards</Button>
        </div>
      </div>
      <figure class="hero-product premium-can">
        <img src="/images/products/premium-artemia-cysts-can.avif" alt="Yellow can of premium Artemia cysts." width="1448" height="1086" loading="eager" />
      </figure>
    </div>
  </section>

  <section class="section premium-benefits-section">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">WHY CHOOSE PREMIUM</span>
        <h2>Uncompromising Consistency for High-Density Rearing</h2>
        <p>When larval survival rates dictate your hatchery's profitability, full batch visibility is essential. Our premium selection eliminates operational variables by providing thoroughly tested hatching profiles, secure export packaging, and rigorous temperature-controlled tracking before shipping.</p>
      </div>
      <div class="benefit-grid">
        {benefits.map((item, index) => (<article class="benefit-card"><img class="premium-benefit-icon" src={item.icon} alt={item.alt} width="58" height="58" loading="lazy" decoding="async" /><span class="step-num">{String(index + 1).padStart(2, '0')} /</span><h3>{item.title}</h3><p>{item.text}</p></article>))}
      </div>
    </div>
  </section>

  <section class="section bg-light premium-spec-section">
    <div class="container two-col">
      <div>
        <span class="eyebrow">SPECIFICATION SNAPSHOT</span>
        <h2>Tailored Supply Programs for Commercial Scale</h2>
        <p>To secure your seasonal supply chain, CIDE FISHERY customizes premium ordering programs based on your facility's feeding schedules, monthly consumption volume, and strict biosecurity compliance. Contact our technical team to map out an optimized inventory rotation plan.</p>
      </div>
      <div class="spec-list">
        {specs.map((spec) => (<div class="spec-row"><span>{spec.label}</span><strong>{spec.value}</strong></div>))}
      </div>
    </div>
  </section>

  <section class="section bg-light">
    <div class="container package-band">
      <div>
        <span class="eyebrow">PACKAGING FOR INDUSTRIAL ORDERS</span>
        <h2>Hermetically Sealed Cans &amp; Premium Export Containment</h2>
        <p>Biological viability relies heavily on the final seal. Our premium Artemia cysts are packed in robust, moisture-proof vacuum cans and heavily lined cartons to eliminate ambient humidity, maintain internal stability during inventory rotation, and withstand rigorous port-of-entry destination handling.</p>
        <div class="hero-ctas">
          <Button href="/about/packaging/" variant="primary" size="lg">View Packaging Options</Button>
          <Button href="/products/artemia-cysts/" variant="outline" size="lg">Compare Standard Artemia Cysts</Button>
        </div>
      </div>
      <img src="/images/products/premium-brine-shrimp-eggs-can.avif" alt="Blue can of premium brine shrimp eggs." width="1448" height="1086" loading="lazy" />
    </div>
  </section>
  <CTASection
    title="Request a Tailored Quote"
    description="Share your hatchery specifications and our team will prepare a customized Artemia cyst supply solution."
    ctaText="Send Inquiry"
    ctaHref="/contact/"
    showInquiryForm
    preselectedProduct="Premium Artemia Cysts"
  />

</BaseLayout>

<style>
  .hero-section { padding: 64px 0; }
  .hero-grid, .two-col, .package-band { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
  .eyebrow { display: inline-block; color: var(--color-brand-blue); font-size: 13px; font-weight: 700; text-transform: uppercase; margin-bottom: 10px; }
  .page-lead { font-size: 18px; opacity: 0.84; margin: 16px 0 24px; }
  .hero-ctas { display: flex; gap: 16px; flex-wrap: wrap; }
  .hero-product, .package-band img { border: 1px solid var(--color-neutral-gray); border-radius: var(--border-radius); background: var(--color-white); overflow: hidden; margin: 0; }
  .hero-product { min-height: 360px; display: flex; align-items: center; justify-content: center; padding: 30px; }
  .hero-product img { max-width: 72%; height: auto; display: block; }
  .premium-benefits-section { padding: 120px 0; }
  .section-head { max-width: 760px; margin-bottom: 28px; }
  .premium-benefits-section .section-head h2 { margin-bottom: 20px; }
  .benefit-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
  .benefit-card { background: var(--color-white); border: 1px solid var(--color-neutral-gray); border-radius: var(--border-radius); padding: 32px; text-align: left; }
  .premium-benefit-icon { display: block; width: 58px; height: 58px; margin: 0 0 20px; object-fit: contain; }
  .step-num { display: block; color: var(--color-champagne-gold); font-weight: 800; text-align: left; }
  .benefit-card h3 { margin: 8px 0; font-size: 20px; }
  .benefit-card p { font-size: var(--fs-small); opacity: 0.8; }
  .spec-list { border: 1px solid var(--color-neutral-gray); border-radius: var(--border-radius); overflow: hidden; }
  .premium-spec-section { padding: 120px 0; }
  .premium-spec-section h2 { margin-bottom: 20px; }
  .spec-row { display: grid; gap: 4px; padding: 16px 18px; background: var(--color-white); border-bottom: 1px solid var(--color-neutral-gray); }
  .spec-row:last-child { border-bottom: 0; }
  .spec-row span { color: var(--color-brand-blue); font-weight: 700; font-size: var(--fs-small); }
  .spec-row strong { font-size: var(--fs-small); }
  .package-band { padding: 68px 58px; border: 1px solid var(--color-neutral-gray); border-radius: var(--border-radius); background: var(--color-white); }
  .package-band h2 { margin-bottom: 20px; }
  .package-band p { margin-bottom: 20px; }
  .package-band img { width: 100%; height: 100%; aspect-ratio: 4 / 3; object-fit: cover; display: block; padding: 0; }
  @media (max-width: 1024px) { .hero-grid, .two-col, .package-band { grid-template-columns: 1fr; } .benefit-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 767px) { .benefit-grid { grid-template-columns: 1fr; } .package-band { padding: 20px; } }
</style>



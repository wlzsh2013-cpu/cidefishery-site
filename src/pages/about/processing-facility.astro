---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import Icon from '../../components/Icon.astro';

const equipment = [
  { label: '7', text: 'Industrial Cleaning & Disinfection Tanks' },
  { label: '2', text: 'High-Speed Centrifuge Units' },
  { label: '6', text: 'Advanced Drying Equipment Sets' },
  { label: '2', text: 'Precision Fluid Suction & Screening Systems' },
  { label: '2', text: 'Heavy Forklifts for Material Handling' },
  { label: '1,000 tons', text: 'Annual Processing Capacity' },
];

const workflow = [
  { icon: 'raw-material-classification', alt: 'Raw material classification icon', title: 'Raw Material Classification', desc: 'Incoming wild harvested cysts are immediately cataloged by region, initial hatch-testing profiles, and contract requirements, guaranteeing full batch traceability before step-one refinement.' },
  { icon: 'automated-washing-screening', alt: 'Automated washing and screening icon', title: 'Automated Washing & Screening', desc: 'Cysts undergo intensive freshwater washing, automated disinfection, and precise fluid density screening to remove heavy debris, broken shells, and impurities without impacting embryo vitality.' },
  { icon: 'controlled-fluid-bed-drying', alt: 'Controlled fluid-bed drying icon', title: 'Controlled Fluid-Bed Drying', desc: 'Utilizing calibrated low-temperature drying equipment and heavy centrifuge banks, we gently reduce moisture content to optimal levels, ensuring perfect diapause termination and long-term shelf stability.' },
  { icon: 'hermetic-packing-export-prep', alt: 'Hermetic packing and export prep icon', title: 'Hermetic Packing & Export Prep', desc: 'Finished goods are immediately vacuum-sealed into multi-layer cans, moisture-barrier bags, or heavy drums. All batches are labeled and logged for global cold-chain transit.' },
];
---
<BaseLayout
  title="Advanced Artemia Cyst Processing Center | CIDE FISHERY"
  description="CIDE FISHERY operates a 4,000 m2 automated Artemia cyst processing facility in Wenchang, Hainan, built for cleaning, drying, screening, cold storage and global B2B export supply."
  ogImage="/images/company/artemia-cyst-processing-clean-workshop.avif"
  breadcrumbs={[{ name: 'About', url: '/about/' }, { name: 'Processing Facility', url: '/about/processing-facility/' }]}
  showBreadcrumb
>
  <section class="section page-header bg-light">
    <div class="container hero-grid">
      <div>
        <span class="eyebrow">PROCESSING FACILITY</span>
        <h1>Advanced Artemia Cyst Processing Center Built for Global B2B Supply</h1>
        <p class="page-lead">CIDE FISHERY operates a world-class, 4,000 m2 automated processing facility within our premier production base in Wenchang, Hainan. Our factory seamlessly integrates specialized raw material handling, rigorous multi-stage cleaning, fluid-bed drying, advanced optical screening, and industrial-grade cold storage. This full-spectrum infrastructure ensures uncompromised biological purity and uniform batch standards for large-scale maritime export.</p>
        <div class="hero-ctas">
          <Button href="/contact/" variant="primary" size="lg">Discuss Processing Capacity</Button>
          <Button href="/about/quality-control/" variant="outline" size="lg">Quality Control</Button>
        </div>
      </div>
      <img src="/images/company/artemia-cyst-processing-clean-workshop.avif" alt="Clean Artemia cyst processing workshop" width="1200" height="675" loading="eager" />
    </div>
  </section>

  <section class="section equipment-section">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">FACILITY FACTS</span>
        <h2>Industrial-Grade Processing Infrastructure &amp; Scale</h2>
        <p>Our massive equipment footprint empowers international importers and commercial hatcheries to secure scalable procurement. Backed by high-capacity automated lines, we maintain flawless batch consistency and strict timing alignment for bulk global contracts.</p>
      </div>
      <div class="equipment-grid">
        {equipment.map((item) => (<div class="equipment-card"><strong>{item.label}</strong><span>{item.text}</span></div>))}
      </div>
    </div>
  </section>

  <section class="section bg-light">
    <div class="container media-grid">
      <img src="/images/company/artemia-cyst-suction-tank-equipment.avif" alt="Artemia cyst suction tank equipment" width="1200" height="900" loading="lazy" />
      <img src="/images/company/artemia-cyst-packaging-materials-warehouse.avif" alt="Artemia cyst packaging materials in warehouse" width="1200" height="801" loading="lazy" />
    </div>
  </section>

  <section class="section bg-light">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">WORKFLOW</span>
        <h2>Rigorous Factory Standards Preserving Biological Integrity</h2>
      </div>
      <div class="workflow-grid">
        {workflow.map((item) => (<article class="workflow-card"><Icon name={item.icon} label={item.alt} desc={item.desc} className="workflow-icon" /><h3>{item.title}</h3><p>{item.desc}</p></article>))}
      </div>
    </div>
  </section>

  <section class="section bg-light"><div class="container related-band"><div><span class="eyebrow">NEXT CHECK</span><h2>Fully Integrated Quality Control, Cold Storage &amp; Customized Packing</h2><p>Peak processing scale is only the foundation. Explore how our advanced manufacturing facility seamlessly links with stringent laboratory testing, 3,000 m³ climate-controlled cold storage, and flexible private labeling options tailored directly to your regional distribution regulations.</p></div><div class="related-links"><a href="/about/quality-control/">Quality Control</a><a href="/about/cold-storage/">Cold Storage</a><a href="/about/packaging/">Packaging</a></div></div></section>
</BaseLayout>
<style>.page-header{padding:64px 0}.hero-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}.hero-grid img,.media-grid img{width:100%;aspect-ratio:4/3;object-fit:cover;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-white)}.eyebrow{display:inline-block;color:var(--color-brand-blue);font-size:13px;font-weight:700;text-transform:uppercase;margin-bottom:10px}.page-lead{font-size:18px;opacity:.84;margin:16px 0 24px}.hero-ctas{display:flex;gap:16px;flex-wrap:wrap}.section-head{max-width:820px;margin-bottom:30px}.equipment-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}.equipment-card{padding:22px;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-white)}.equipment-card strong{display:block;font-size:30px;color:var(--color-brand-blue)}.equipment-card span{display:block;margin-top:4px;font-size:var(--fs-small);opacity:.78}.media-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}.workflow-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}.workflow-card{display:block;min-height:260px;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);padding:24px;background:var(--color-white);color:var(--color-text)}.workflow-card :global(.workflow-icon){display:flex;width:58px;height:58px;margin-bottom:0;align-items:center;justify-content:center}.workflow-card h3{font-size:20px;font-weight:800;color:var(--color-primary);margin:22px 0 0}.workflow-card p{margin-top:10px;font-size:var(--fs-small);line-height:1.6;opacity:.78}.related-band{display:grid;grid-template-columns:calc(68% - 14px) calc(32% - 14px);gap:28px;align-items:center;padding:28px;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-white)}.related-band h2{margin:0 0 20px}.related-band p{margin:0}.related-links{display:flex;gap:12px;flex-wrap:wrap;justify-content:center}.related-links a{padding:12px 16px;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-light-bg);font-weight:700}@media(max-width:1024px){.hero-grid,.media-grid{grid-template-columns:1fr}.equipment-grid,.workflow-grid{grid-template-columns:repeat(2,1fr)}.related-band{grid-template-columns:1fr;align-items:flex-start}.related-links{justify-content:flex-start}}@media(max-width:767px){.equipment-grid,.workflow-grid{grid-template-columns:1fr}}</style>


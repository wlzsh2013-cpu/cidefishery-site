---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import Icon from '../../components/Icon.astro';

const qcSteps = [
  {
    icon: 'origin-batch-traceability',
    title: 'Origin & Batch Traceability',
    desc: 'Every cargo container is assigned a unique batch tracking profile, documenting specific harvest waters, raw material grading metrics, and target species suitability logs.',
  },
  {
    icon: 'advanced-refining-control',
    title: 'Advanced Refining Control',
    desc: 'We monitor automated fluid washing, density screening, and low-temperature bed drying in real time, locking in premium embryonic survival across all automated lines.',
  },
  {
    icon: 'storage-inventory-log',
    title: 'Storage & Inventory Log',
    desc: 'Continuous digital monitoring across our 3,000 m3 cold-storage facility guarantees zero temperature fluctuations, preserving stable long-term cyst hatchability.',
  },
  {
    icon: 'hermetic-integrity-verification',
    title: 'Hermetic Integrity Verification',
    desc: 'We run specialized pressure and seals checks on all export-ready vacuum cans, high-barrier foil bags, and heavy drums to eliminate moisture ingress during oceanic transit.',
  },
];

const documents = [
  {
    image: '/images/company/cide-fishery-iso-14001-environmental-certificate.avif',
    width: 800,
    height: 1174,
    title: 'Regulatory Compliance Materials',
    desc: 'Environmental management certification supporting regulatory review and supplier compliance checks.',
    alt: 'CIDE FISHERY ISO 14001 environmental certificate',
  },
  {
    image: '/images/company/cide-fishery-iso-9001-quality-certificate.avif',
    width: 800,
    height: 1132,
    title: 'International System Certification',
    desc: 'Quality management system certification for documented Artemia cyst sales and management activities.',
    alt: 'CIDE FISHERY ISO 9001 quality certificate',
  },
  {
    image: '/images/company/cide-fishery-specialized-sme-certificate.avif',
    width: 800,
    height: 600,
    title: 'Official Supplier Evaluation Records',
    desc: 'Official enterprise qualification material for distributor onboarding and procurement review.',
    alt: 'CIDE FISHERY specialized SME certificate',
  },
];

const buyerChecks = [
  {
    number: '01',
    title: 'Target Application Specs',
    text: 'Specify your destination species (e.g., SPF shrimp postlarvae, marine fish fry) and current feeding density routines.',
  },
  {
    number: '02',
    title: 'Packaging Allocation',
    text: 'Select your ideal multi-layer export formats (hermetically sealed cans, multi-weight barrier foil bags, or unbranded neutral drums).',
  },
  {
    number: '03',
    title: 'Cold-Chain Logistics Setup',
    text: "Outline your facility's localized storage capacities and expected annual inventory rotation schedules for optimized transit planning.",
  },
  {
    number: '04',
    title: 'Regulatory Documentation',
    text: 'Request required certificates, localized operating permits, or independent lab tracking logs necessary for your regional customs entry.',
  },
];
---
<BaseLayout
  title="Artemia Cyst Quality Control and Audit Documentation | CIDE FISHERY"
  description="Review CIDE FISHERY quality control systems for global hatchery audits, including batch traceability, refining control, cold-chain logs, packaging checks and supplier documentation."
  ogImage="/images/company/cide-fishery-iso-45001-health-safety-certificate-qc.avif"
  breadcrumbs={[{ name: 'About', url: '/about/' }, { name: 'Quality Control', url: '/about/quality-control/' }]}
  showBreadcrumb
>
  <section class="section page-header bg-light">
    <div class="container hero-grid">
      <div>
        <span class="eyebrow">QUALITY AND DOCUMENTATION</span>
        <h1>Rigorous Quality Control Systems Supporting Global Hatchery Audits</h1>
        <p class="page-lead">For international commercial hatcheries and high-volume importers, chemical and biological compliance is non-negotiable. CIDE FISHERY implements an uncompromised, laboratory-verified quality control standard. We provide total batch transparency, from certified hatch synchronization curves to verified cold-chain logs, ensuring every container load satisfies your localized biosecurity evaluations and import regulations.</p>
        <div class="hero-ctas">
          <Button href="/contact/" variant="primary" size="lg">Request Batch Information</Button>
          <Button href="/about/processing-facility/" variant="outline" size="lg">Processing Facility</Button>
        </div>
      </div>
      <img src="/images/company/cide-fishery-iso-45001-health-safety-certificate-qc.avif" alt="CIDE FISHERY ISO 45001 health and safety certificate" width="800" height="1153" loading="eager" />
    </div>
  </section>

  <section class="section bg-light">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">QC WORKFLOW</span>
        <h2>Stringent Pre-Export Audits Safeguarding Biological Vitality</h2>
        <p>Quality is a measurable reality, not a marketing claim. CIDE FISHERY tracks and logs critical biological and physical benchmarks across every processing phase, delivering fully verified batch documentation before container sealing and port dispatch.</p>
      </div>
      <div class="features-grid">
        {qcSteps.map((f) => (
          <article class="feature-card">
            <Icon name={f.icon} label={`${f.title} icon`} desc={f.desc} className="feature-icon" />
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-light">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">SUPPLIER PROOF</span>
        <h2>International Standard Certifications &amp; Supplier Evaluation Materials</h2>
        <p>Accelerate your corporate distributor onboarding and internal purchasing compliance review. Contact our trade specialists to obtain the latest certified copies and certified laboratory logs matching your destination country.</p>
      </div>
      <div class="document-grid">
        {documents.map((doc) => (
          <figure class="document-card">
            <img src={doc.image} alt={doc.alt} width={doc.width} height={doc.height} loading="lazy" />
            <figcaption>
              <strong>{doc.title}</strong>
              <span>{doc.desc}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container two-col">
      <div>
        <span class="eyebrow">BUYER CHECKLIST</span>
        <h2>Accelerate Technical Alignment and Custom Quote Verification</h2>
        <p>To ensure our technical laboratory and logistics experts engineer a highly precise commercial proposal for your specific aquaculture environment, please include the following parameters in your inquiry:</p>
      </div>
      <div class="check-list">
        {buyerChecks.map((item) => (
          <div class="check-item">
            <strong>{item.number} /</strong>
            <div>
              <h3>{item.title}</h3>
              <span>{item.text}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
<style>.page-header{padding:64px 0}.hero-grid,.two-col{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}.hero-grid img{width:100%;max-height:460px;object-fit:contain;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-white);padding:18px}.eyebrow{display:inline-block;color:var(--color-brand-blue);font-size:13px;font-weight:700;text-transform:uppercase;margin-bottom:10px}.page-lead{font-size:18px;opacity:.84;margin:16px 0 24px}.hero-ctas{display:flex;gap:16px;flex-wrap:wrap}.section-head{max-width:820px;margin-bottom:30px}.section-head h2,.two-col>div:first-child h2{margin:0 0 20px}.section-head p,.two-col>div:first-child p{margin:0}.features-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}.feature-card{display:block;min-height:260px;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);padding:24px;background:var(--color-white);color:var(--color-text)}.feature-card :global(.feature-icon){display:flex;width:58px;height:58px;margin-bottom:0;align-items:center;justify-content:center}.feature-card h3{font-size:20px;font-weight:800;color:var(--color-primary);margin:22px 0 0}.feature-card p{margin-top:10px;font-size:var(--fs-small);line-height:1.6;opacity:.78}.document-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}.document-card{margin:0;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-white);overflow:hidden}.document-card img{width:100%;height:360px;object-fit:contain;padding:18px;background:var(--color-light-bg)}.document-card figcaption{padding:18px 20px 20px;text-align:center}.document-card figcaption strong{display:block;color:var(--color-primary);font-size:20px;font-weight:800}.document-card figcaption span{display:block;margin-top:10px;font-size:var(--fs-small);line-height:1.55;opacity:.78}.check-list{display:grid;gap:12px}.check-item{display:grid;grid-template-columns:56px 1fr;gap:14px;padding:16px 18px;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-white)}.check-item strong{color:var(--color-champagne-gold);font-size:24px;line-height:1;font-weight:800}.check-item h3{margin:0 0 6px;font-size:20px;color:var(--color-primary)}.check-item span{display:block;font-size:var(--fs-small);line-height:1.6;opacity:.8}@media(max-width:1024px){.hero-grid,.two-col{grid-template-columns:1fr}.features-grid{grid-template-columns:repeat(2,1fr)}}@media(max-width:767px){.features-grid,.document-grid{grid-template-columns:1fr}.check-item{grid-template-columns:1fr}}</style>

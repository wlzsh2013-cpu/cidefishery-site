---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import Icon from '../../components/Icon.astro';

const storageFacts = [
  { value: '8', label: 'dedicated cold-storage rooms' },
  { value: '1,000 m2', label: 'cold-storage area' },
  { value: '3,000 m3', label: 'storage capacity' },
  { value: 'B2B', label: 'inventory and shipment planning' },
];

const storagePoints = [
  { icon: 'cold-storage', title: 'Pre-Export Storage', desc: 'Dedicated cold-storage rooms support Artemia cyst handling before packing, shipment or distributor delivery.' },
  { icon: 'quality-control', title: 'Inventory Rotation', desc: 'Order volume, storage time and dispatch schedule should be planned together for recurring supply.' },
  { icon: 'packaging', title: 'Package Protection', desc: 'Packaging format should support storage, transit and warehouse handling in the destination market.' },
  { icon: 'global-supply', title: 'Shipment Coordination', desc: 'Cold-storage planning is connected with destination, logistics route and expected delivery window.' },
];
---
<BaseLayout
  title="Cold Storage for Artemia Cysts | CIDE FISHERY"
  description="CIDE FISHERY cold storage page for Artemia cyst supply, covering 8 dedicated cold rooms, 1,000 m2 storage area, 3,000 m3 capacity and B2B shipment planning."
  ogImage="/images/company/artemia-cyst-cold-storage-rooms.jpg"
  breadcrumbs={[{ name: 'About', url: '/about/' }, { name: 'Cold Storage', url: '/trust/cold-storage/' }]}
  showBreadcrumb
>
  <section class="section page-header bg-light"><div class="container hero-grid"><div><span class="eyebrow">Cold storage capability</span><h1>Cold Storage Support for Artemia Cyst Stability and Shipment Planning</h1><p class="page-lead">Artemia cyst procurement does not end at processing. Storage condition, inventory rotation, packaging format and dispatch timing all affect how reliably hatcheries and distributors can use the product after arrival.</p><div class="hero-ctas"><Button href="/contact/" variant="primary" size="lg">Ask About Storage Plan</Button><Button href="/trust/packaging/" variant="outline" size="lg">Packaging Options</Button></div></div><img src="/images/company/artemia-cyst-cold-storage-rooms.jpg" alt="CIDE FISHERY cold storage rooms for Artemia cyst supply" width="1600" height="1200" loading="eager" /></div></section>
  <section class="section stats-section"><div class="container stats-grid">{storageFacts.map((item)=>(<div class="stat-card"><strong>{item.value}</strong><span>{item.label}</span></div>))}</div></section>
  <section class="section bg-light"><div class="container media-band"><img src="/images/company/artemia-cyst-warehouse-packaging.jpg" alt="Artemia cyst packaged inventory and warehouse handling" width="1600" height="1068" loading="lazy" /><div><span class="eyebrow">Storage decisions</span><h2>What Buyers Should Confirm Before Shipment</h2><p>For recurring orders, tell us destination, estimated transit time, warehouse condition, monthly demand and package preference. This helps us discuss a storage and dispatch plan that fits your supply program.</p><div class="features-list">{storagePoints.map((f)=>(<article><Icon name={f.icon} label={`${f.title} icon`} desc={f.desc} className="mini-icon"/><div><h3>{f.title}</h3><p>{f.desc}</p></div></article>))}</div></div></div></section>
</BaseLayout>
<style>.page-header{padding:64px 0}.hero-grid,.media-band{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}.hero-grid img,.media-band img{width:100%;aspect-ratio:4/3;object-fit:cover;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-white)}.eyebrow{display:inline-block;color:var(--color-brand-blue);font-size:13px;font-weight:700;text-transform:uppercase;margin-bottom:10px}.page-lead{font-size:18px;opacity:.84;margin:16px 0 24px}.hero-ctas{display:flex;gap:16px;flex-wrap:wrap}.stats-section{padding:32px 0;background:var(--color-primary)}.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}.stat-card{padding:20px;border:1px solid rgba(255,255,255,.18);border-radius:var(--border-radius)}.stat-card strong,.stat-card span{display:block;color:var(--color-white)}.stat-card strong{font-size:28px}.stat-card span{font-size:var(--fs-small);opacity:.8}.features-list{display:grid;gap:14px;margin-top:22px}.features-list article{display:flex;gap:12px;padding:14px;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-white)}.mini-icon{width:38px;height:38px;flex:0 0 auto}.features-list h3{font-size:18px;margin:0 0 4px}.features-list p{font-size:var(--fs-small);opacity:.8;margin:0}@media(max-width:1024px){.hero-grid,.media-band{grid-template-columns:1fr}.stats-grid{grid-template-columns:repeat(2,1fr)}}@media(max-width:767px){.stats-grid{grid-template-columns:1fr}}</style>

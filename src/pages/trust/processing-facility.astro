---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import Icon from '../../components/Icon.astro';

const equipment = [
  { label: '7', text: 'cleaning and disinfection tanks' },
  { label: '2', text: 'centrifuge units' },
  { label: '6', text: 'drying equipment sets' },
  { label: '2', text: 'suction and screening systems' },
  { label: '2', text: 'forklifts for material handling' },
  { label: '1,000 tons', text: 'annual processing capacity' },
];

const workflow = [
  { icon: 'processing', title: 'Raw Material Receiving', desc: 'Incoming Artemia cyst materials are organized by source, order requirement and processing plan before further handling.' },
  { icon: 'quality-control', title: 'Cleaning and Screening', desc: 'Cleaning, disinfection, suction and screening steps support product preparation and batch communication.' },
  { icon: 'processing', title: 'Drying and Handling', desc: 'Drying equipment, centrifuges and controlled workshop procedures support the processing flow before packaging.' },
  { icon: 'packaging', title: 'Packing and Export Preparation', desc: 'Finished goods can be prepared for cans, bags, drums, cartons or distributor-oriented packing programs.' },
];
---
<BaseLayout
  title="Artemia Cyst Processing Facility and Equipment | CIDE FISHERY"
  description="View CIDE FISHERY Artemia cyst processing facility in Hainan, including 4,000 m2 processing area, cleaning tanks, centrifuges, drying equipment, screening systems and export packing support."
  ogImage="/images/company/artemia-processing-workshop.jpg"
  breadcrumbs={[{ name: 'About', url: '/about/' }, { name: 'Processing Facility', url: '/trust/processing-facility/' }]}
  showBreadcrumb
>
  <section class="section page-header bg-light">
    <div class="container hero-grid">
      <div>
        <span class="eyebrow">Processing facility</span>
        <h1>Artemia Cyst Processing Facility Built for B2B Supply</h1>
        <p class="page-lead">CIDE FISHERY operates an Artemia cyst processing area of about 4,000 m2 inside its Wenchang, Hainan production base. The facility connects raw material handling, cleaning, screening, drying, cold storage and export packing.</p>
        <div class="hero-ctas">
          <Button href="/contact/" variant="primary" size="lg">Discuss Processing Capacity</Button>
          <Button href="/trust/quality-control/" variant="outline" size="lg">Quality Control</Button>
        </div>
      </div>
      <img src="/images/company/artemia-processing-workshop.jpg" alt="CIDE FISHERY Artemia cyst processing workshop in Hainan" width="1600" height="900" loading="eager" />
    </div>
  </section>

  <section class="section equipment-section">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Facility facts</span>
        <h2>Processing Equipment and Production Support</h2>
        <p>These operating details help importers and hatchery procurement teams understand whether CIDE FISHERY can support repeat orders, bulk programs and export packing schedules.</p>
      </div>
      <div class="equipment-grid">
        {equipment.map((item) => (<div class="equipment-card"><strong>{item.label}</strong><span>{item.text}</span></div>))}
      </div>
    </div>
  </section>

  <section class="section bg-light">
    <div class="container media-grid">
      <img src="/images/company/artemia-processing-equipment.jpg" alt="Artemia cyst processing tanks and equipment at CIDE FISHERY" width="1600" height="747" loading="lazy" />
      <img src="/images/company/artemia-cyst-warehouse-packaging.jpg" alt="Artemia cyst warehouse packaging materials for export supply" width="1600" height="1068" loading="lazy" />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Workflow</span>
        <h2>How Facility Capability Supports Buyers</h2>
      </div>
      <div class="workflow-grid">
        {workflow.map((item) => (<article class="workflow-card"><Icon name={item.icon} label={`${item.title} icon`} desc={item.desc} className="workflow-icon" /><h3>{item.title}</h3><p>{item.desc}</p></article>))}
      </div>
    </div>
  </section>

  <section class="section bg-light"><div class="container related-band"><div><span class="eyebrow">Next check</span><h2>Review Quality, Cold Storage and Packaging Together</h2><p>Processing capacity becomes more useful when it is connected with QC communication, cold storage capacity and suitable packaging for the buyer's market.</p></div><div class="related-links"><a href="/trust/quality-control/">Quality Control</a><a href="/trust/cold-storage/">Cold Storage</a><a href="/trust/packaging/">Packaging</a></div></div></section>
</BaseLayout>
<style>.page-header{padding:64px 0}.hero-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}.hero-grid img,.media-grid img{width:100%;aspect-ratio:4/3;object-fit:cover;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-white)}.eyebrow{display:inline-block;color:var(--color-brand-blue);font-size:13px;font-weight:700;text-transform:uppercase;margin-bottom:10px}.page-lead{font-size:18px;opacity:.84;margin:16px 0 24px}.hero-ctas{display:flex;gap:16px;flex-wrap:wrap}.section-head{max-width:800px;margin-bottom:28px}.equipment-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}.equipment-card{padding:22px;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-white)}.equipment-card strong{display:block;font-size:30px;color:var(--color-brand-blue)}.equipment-card span{display:block;margin-top:4px;font-size:var(--fs-small);opacity:.78}.media-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}.workflow-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}.workflow-card{border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);padding:22px;background:var(--color-white)}.workflow-icon{width:54px;height:54px;margin-bottom:12px}.workflow-card h3{font-size:20px}.workflow-card p{font-size:var(--fs-small);opacity:.8}.related-band{display:flex;justify-content:space-between;gap:28px;align-items:center;padding:28px;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-white)}.related-links{display:flex;gap:12px;flex-wrap:wrap}.related-links a{padding:12px 16px;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-light-bg);font-weight:700}@media(max-width:1024px){.hero-grid,.media-grid{grid-template-columns:1fr}.equipment-grid,.workflow-grid{grid-template-columns:repeat(2,1fr)}.related-band{align-items:flex-start;flex-direction:column}}@media(max-width:767px){.equipment-grid,.workflow-grid{grid-template-columns:1fr}}</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import Icon from '../../components/Icon.astro';

const formats = [
  { icon: 'packaging', title: 'Vacuum Cans', desc: 'Suitable for hatcheries and distributors that need convenient handling, clear labeling and stable inventory rotation.' },
  { icon: 'packaging', title: 'Foil Bags', desc: 'Useful for flexible order planning, distributor channels and cost-conscious packing discussions.' },
  { icon: 'packaging', title: 'Paper Drums and Cartons', desc: 'Practical for bulk handling, warehouse movement and export packing programs.' },
  { icon: 'quality-control', title: 'Label and Document Discussion', desc: 'Distributor labeling, carton marks and supplier documents can be discussed according to buyer requirements.' },
];

const decisions = [
  'Product type: standard Artemia cysts, premium batches, decapsulated eggs or bulk supply.',
  'Order volume and resale channel: hatchery direct use, importer stock or distributor repacking.',
  'Storage condition and expected inventory rotation in the destination market.',
  'Destination country, shipping route, carton marks and documentation expectations.'
];
---
<BaseLayout
  title="Artemia Cyst Packaging Options for Export Supply | CIDE FISHERY"
  description="Packaging options for Artemia cyst export supply, including vacuum cans, foil bags, drums, cartons, custom labeling discussion and B2B distributor packing planning."
  ogImage="/images/products/bulk-artemia-packaging.jpg"
  breadcrumbs={[{ name: 'About', url: '/about/' }, { name: 'Packaging', url: '/trust/packaging/' }]}
  showBreadcrumb
>
  <section class="section page-header bg-light"><div class="container hero-grid"><div><span class="eyebrow">Packaging options</span><h1>Packaging Formats for Hatchery, Importer and Distributor Supply</h1><p class="page-lead">Packaging is part of the buying decision for Artemia cysts. The right format should match product type, storage plan, order volume, destination handling and distributor requirements.</p><div class="hero-ctas"><Button href="/contact/" variant="primary" size="lg">Discuss Packaging</Button><Button href="/products/bulk-artemia-cysts/" variant="outline" size="lg">Bulk Supply</Button></div></div><img src="/images/products/bulk-artemia-packaging.jpg" alt="Bulk Artemia cyst packaging bags for export supply and distributors" width="2679" height="2346" loading="eager" /></div></section>
  <section class="section"><div class="container"><div class="section-head"><span class="eyebrow">Available formats</span><h2>Choose Packaging by Market and Handling Plan</h2></div><div class="features-grid">{formats.map((f)=>(<article class="feature-card"><Icon name={f.icon} label={`${f.title} icon`} desc={f.desc} className="feature-icon"/><h3>{f.title}</h3><p>{f.desc}</p></article>))}</div></div></section>
  <section class="section bg-light"><div class="container media-band"><img src="/images/company/artemia-cyst-warehouse-packaging.jpg" alt="Artemia cyst warehouse packaging and export preparation" width="1600" height="1068" loading="lazy" /><div><span class="eyebrow">Before quotation</span><h2>Packaging Details Buyers Should Send</h2><p>Providing these details helps CIDE FISHERY recommend a practical packing route instead of a generic offer.</p><ul>{decisions.map((item)=>(<li>{item}</li>))}</ul><div class="hero-ctas"><Button href="/trust/cold-storage/" variant="outline" size="lg">Cold Storage</Button><Button href="/trust/quality-control/" variant="outline" size="lg">Quality Control</Button></div></div></div></section>
</BaseLayout>
<style>.page-header{padding:64px 0}.hero-grid,.media-band{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}.hero-grid img,.media-band img{width:100%;aspect-ratio:4/3;object-fit:cover;border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);background:var(--color-white)}.eyebrow{display:inline-block;color:var(--color-brand-blue);font-size:13px;font-weight:700;text-transform:uppercase;margin-bottom:10px}.page-lead{font-size:18px;opacity:.84;margin:16px 0 24px}.hero-ctas{display:flex;gap:16px;flex-wrap:wrap;margin-top:22px}.section-head{max-width:780px;margin-bottom:28px}.features-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}.feature-card{border:1px solid var(--color-neutral-gray);border-radius:var(--border-radius);padding:22px;background:var(--color-white)}.feature-icon{width:54px;height:54px;margin-bottom:12px}.feature-card h3{font-size:20px}.feature-card p{font-size:var(--fs-small);opacity:.8}.media-band ul{padding-left:20px;margin-top:18px}.media-band li{margin-bottom:10px}@media(max-width:1024px){.hero-grid,.media-band{grid-template-columns:1fr}.features-grid{grid-template-columns:repeat(2,1fr)}}@media(max-width:767px){.features-grid{grid-template-columns:1fr}}</style>

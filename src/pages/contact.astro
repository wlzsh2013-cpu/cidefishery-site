---

import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import Icon from '../components/Icon.astro';

const inquiryTips = [
  { icon: 'shrimp-hatchery', text: 'Hatchery type and target species' },
  { icon: 'global-supply', text: 'Monthly purchase volume estimate' },
  { icon: 'global-supply', text: 'Destination country' },
  { icon: 'packaging', text: 'Preferred packaging format' },
  { icon: 'cold-storage', text: 'Desired delivery schedule' },
];
---
<BaseLayout
  title="Contact CIDE FISHERY | Request Artemia Cysts Quote"
  description="Contact CIDE FISHERY for Artemia cyst inquiries, bulk supply requests, batch information and packaging discussions. Serving hatcheries and distributors worldwide."
  breadcrumbs={[{ name: 'Contact', url: '/contact/' }]}
  showBreadcrumb
>
  <section class="section page-header bg-light">
    <div class="container">
      <h1>Contact CIDE FISHERY</h1>
      <p class="page-lead">Send an inquiry about Artemia cyst supply, batch information or packaging options. We respond to business inquiries within 1-2 business days.</p>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:800px;margin:0 auto;">
      <div class="contact-layout">
        <div>
          <ContactForm
            title="Send an Inquiry"
            subtitle="Fill out the form below and our team will respond with relevant product information and options."
          />
        </div>
        <div class="contact-sidebar">
          <div class="info-card">
            <h3>Contact Information</h3>
            <p><strong>Email:</strong> info@cidefishery.com</p>
          </div>

          <div class="info-card">
            <h3>What to Include in Your Inquiry</h3>
            <ul class="inquiry-tips">
              {inquiryTips.map((item) => (
                <li>
                  <Icon name={item.icon} label={`${item.text} icon`} desc={item.text} className="tip-icon" />
                  <span>{item.text}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="info-card">
            <h3>Quick Links</h3>
            <ul>
              <li><a href="/products/">Browse Products</a></li>
              <li><a href="/trust/quality-control/">Quality Control</a></li>
              <li><a href="/trust/packaging/">Packaging Options</a></li>
              <li><a href="/faq/">FAQ</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
<style>
  .page-header { padding: 60px 0; }
  .page-lead { font-size: 18px; opacity: 0.8; margin-top: 12px; max-width: 600px; }
  .contact-layout { display: grid; grid-template-columns: 1.2fr 1fr; gap: 40px; align-items: start; }
  .contact-sidebar { display: flex; flex-direction: column; gap: 24px; }
  .info-card { background: var(--color-light-bg); border-radius: var(--border-radius); padding: 24px; }
  .info-card h3 { margin-bottom: 12px; font-size: 18px; }
  .info-card ul { list-style: none; }
  .info-card ul li { margin-bottom: 8px; font-size: var(--fs-small); }
  .inquiry-tips li { display: flex; align-items: center; gap: 10px; font-size: var(--fs-small); padding: 4px 0; }
  .tip-icon { width: 34px; height: 34px; }
  @media (max-width: 1024px) { .contact-layout { grid-template-columns: 1fr; } }
</style>

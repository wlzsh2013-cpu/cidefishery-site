---

<BaseLayout
  title="Contact CIDE FISHERY | Request Artemia Cysts Quote"
  description="Contact CIDE FISHERY for Artemia cyst inquiries, bulk supply requests, batch information and packaging discussions."
  breadcrumbs={[{ name: 'Contact', url: '/contact/' }]}
  showBreadcrumb
>
  <!-- Page Header -->
  <section class="contact-page-header">
    <div class="container">
      <h1>Contact CIDE FISHERY</h1>
      <p class="contact-page-lead">Send an inquiry about Artemia cyst supply, batch information or packaging options. We respond within 1-2 business days.</p>
    </div>
  </section>

  <!-- Main Content -->
  <section class="contact-main-section">
    <div class="container">
      <div class="contact-two-col">

        <!-- Inquiry Form -->
        <div class="contact-form-wrap">
          <div class="inquiry-form-box">
            <div class="form-header">
              <h2>Send a Supply Inquiry</h2>
              <p>Share a few details and our team will reply with a practical supply route.</p>
            </div>

            <form class="form-grid" method="POST" action="/api/inquiry">
              <label>
                <span>Name *</span>
                <input type="text" name="name" autocomplete="name" required placeholder="Your name" />
              </label>
              <label>
                <span>Email *</span>
                <input type="email" name="email" autocomplete="email" required placeholder="you@example.com" />
              </label>
              <label>
                <span>Company</span>
                <input type="text" name="company" autocomplete="organization" placeholder="Company name" />
              </label>
              <label>
                <span>Destination Country *</span>
                <input type="text" name="country" autocomplete="country-name" required placeholder="Country / market" />
              </label>
              <div class="form-field">
                <span>Product Interest</span>
                <div class="custom-select" data-custom-select>
                  <input type="hidden" name="product" value="" />
                  <button type="button" class="select-toggle" aria-haspopup="listbox" aria-expanded="false">
                    <span data-selected-label>Select product</span>
                  </button>
                  <ul class="select-menu" role="listbox">
                    <li role="option" data-value="">Select product</li>
                    <li role="option" data-value="Artemia Cysts">Artemia Cysts</li>
                    <li role="option" data-value="Premium Artemia Cysts">Premium Artemia Cysts</li>
                    <li role="option" data-value="Decapsulated Brine Shrimp Eggs">Decapsulated Brine Shrimp Eggs</li>
                    <li role="option" data-value="Bulk Artemia Cysts">Bulk Artemia Cysts</li>
                  </ul>
                </div>
              </div>
              <div class="form-field">
                <span>Monthly Volume</span>
                <div class="custom-select" data-custom-select>
                  <input type="hidden" name="quantity" value="" />
                  <button type="button" class="select-toggle" aria-haspopup="listbox" aria-expanded="false">
                    <span data-selected-label>Select range</span>
                  </button>
                  <ul class="select-menu" role="listbox">
                    <li role="option" data-value="">Select range</li>
                    <li role="option" data-value="Under 50 kg">Under 50 kg</li>
                    <li role="option" data-value="50 - 200 kg">50 - 200 kg</li>
                    <li role="option" data-value="200 - 1000 kg">200 - 1000 kg</li>
                    <li role="option" data-value="Above 1000 kg">Above 1000 kg</li>
                  </ul>
                </div>
              </div>
              <label class="form-full">
                <span>Message *</span>
                <textarea name="message" rows="5" required placeholder="Tell us about your hatchery type, target species, and requirements..."></textarea>
              </label>
              <button type="submit" class="submit-btn">Submit Inquiry</button>
            </form>
          </div>
        </div>

        <!-- Contact Info Sidebar -->
        <aside class="contact-info-wrap">
          <div class="info-card">
            <h2>Contact Details</h2>

            <div class="info-item">
              <div class="info-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M12 2.25C8.14 2.25 5 5.39 5 9.25c0 5.35 6.24 11.93 6.5 12.2a.7.7 0 0 0 1 0c.26-.27 6.5-6.85 6.5-12.2 0-3.86-3.14-7-7-7Zm0 10.2a3.2 3.2 0 1 1 0-6.4 3.2 3.2 0 0 1 0 6.4Z"/></svg>
              </div>
              <div class="info-body">
                <span class="info-label">Address</span>
                <span class="info-value">CIDE FISHERY, China</span>
              </div>
            </div>

            <div class="info-item">
              <div class="info-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M6.62 10.79a15.1 15.1 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24 11.4 11.4 0 0 0 3.58.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .57 3.58 1 1 0 0 1-.24 1.01l-2.21 2.2Z"/></svg>
              </div>
              <div class="info-body">
                <span class="info-label">Phone</span>
                <a href="tel:+8600000000000" class="info-value info-link">+86 000 0000 0000</a>
              </div>
            </div>

            <div class="info-item">
              <div class="info-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M20.5 4h-17A2.5 2.5 0 0 0 1 6.5v11A2.5 2.5 0 0 0 3.5 20h17a2.5 2.5 0 0 0 2.5-2.5v-11A2.5 2.5 0 0 0 20.5 4Zm-.34 3.1-7.18 5.58a1.58 1.58 0 0 1-1.96 0L3.84 7.1a.75.75 0 0 1 .92-1.18L12 11.55l7.24-5.63a.75.75 0 0 1 .92 1.18Z"/></svg>
              </div>
              <div class="info-body">
                <span class="info-label">Email</span>
                <a href="mailto:info@cidefishery.com" class="info-value info-link">info@cidefishery.com</a>
              </div>
            </div>

            <div class="info-social">
              <span class="social-label">Follow Us</span>
              <div class="social-icons">
                {socialLinks.map((s) => (
                  <a href={s.href} target="_blank" rel="noopener" aria-label={s.name} class="social-icon">
                    <svg viewBox="0 0 24 24"><path d={s.path}/></svg>
                  </a>
                ))}
              </div>
            </div>
          </div>

          <div class="info-card quick-links">
            <h2>Quick Links</h2>
            <ul>
              <li><a href="/products/">Browse Products</a></li>
              <li><a href="/about/quality-control/">Quality Control</a></li>
              <li><a href="/about/packaging/">Packaging Options</a></li>
              <li><a href="/faq/">FAQ</a></li>
            </ul>
          </div>
        </aside>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Page Header */
  .contact-page-header {
    background: linear-gradient(135deg, #0B1F33, #061524);
    padding: clamp(60px, 8vw, 100px) 0;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .contact-page-header::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 30%, rgba(30,95,168,0.15), transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(53,183,216,0.1), transparent 50%);
    pointer-events: none;
  }

  .contact-page-header h1 {
    color: #ffffff !important;
    font-size: clamp(32px, 5vw, 48px);
    margin-bottom: 16px;
    position: relative;
  }

  .contact-page-lead {
    color: rgba(255,255,255,0.70);
    font-size: clamp(16px, 2vw, 18px);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
    position: relative;
  }

  /* Main Section */
  .contact-main-section {
    padding: clamp(60px, 8vw, 100px) 0;
    background: var(--color-light-bg);
  }

  .contact-two-col {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: clamp(32px, 5vw, 56px);
    align-items: start;
  }

  /* Inquiry Form */
  .inquiry-form-box {
    padding: clamp(28px, 4vw, 44px);
    background: var(--color-white);
    border-radius: var(--border-radius);
    }

  .form-header {
    margin-bottom: 28px;
  }

  .form-header h2 {
    margin: 0 0 8px;
    color: var(--color-primary);
    font-size: clamp(22px, 3vw, 28px);
    line-height: 1.15;
  }

  .form-header p {
    margin: 0;
    color: rgba(16,32,48,0.6);
    font-size: 14px;
    line-height: 1.5;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }

  .form-grid label,
  .form-grid .form-field {
    display: grid;
    gap: 7px;
  }

  .form-grid label span,
  .form-grid .form-field > span {
    color: var(--color-primary);
    font-size: 13px;
    font-weight: 700;
  }

  .form-full {
    grid-column: 1 / -1;
  }

  .form-grid input,
  .form-grid textarea {
    width: 100%;
    box-sizing: border-box;
    height: 48px;
    border: 1px solid rgba(11,31,51,0.18);
    border-radius: 6px;
    background: var(--color-white);
    color: var(--color-text);
    font-family: var(--font-family);
    font-size: 15px;
    padding: 11px 14px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .form-grid textarea {
    min-height: 120px;
    height: auto;
    resize: vertical;
  }

  .form-grid input::placeholder,
  .form-grid textarea::placeholder {
    color: rgba(16,32,48,0.4);
  }

  .form-grid input:focus,
  .form-grid textarea:focus {
    outline: none;
    border-color: var(--color-brand-blue);
    box-shadow: 0 0 0 3px rgba(30,95,168,0.1);
  }

  /* Custom Select */
  .custom-select {
    position: relative;
  }

  .select-toggle {
    position: relative;
    width: 100%;
    height: 48px;
    box-sizing: border-box;
    border: 1px solid rgba(11,31,51,0.18);
    border-radius: 6px;
    background: var(--color-white);
    color: var(--color-text);
    cursor: pointer;
    font-family: var(--font-family);
    font-size: 15px;
    padding: 11px 38px 11px 14px;
    text-align: left;
  }

  .select-toggle::after {
    content: "";
    position: absolute;
    right: 14px;
    top: 50%;
    width: 8px;
    height: 8px;
    border-right: 2px solid var(--color-primary);
    border-bottom: 2px solid var(--color-primary);
    transform: translateY(-65%) rotate(45deg);
    opacity: 0.5;
  }

  .select-menu {
    position: absolute;
    z-index: 20;
    left: 0;
    right: 0;
    top: calc(100% + 4px);
    display: none;
    margin: 0;
    padding: 6px;
    list-style: none;
    border: 1px solid var(--color-neutral-gray);
    border-radius: 6px;
    background: var(--color-white);
    box-shadow: 0 12px 32px rgba(11,31,51,0.15);
  }

  .custom-select.is-open .select-menu {
    display: grid;
    gap: 2px;
  }

  .select-menu li {
    padding: 10px 14px;
    border-radius: 4px;
    color: var(--color-primary);
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
  }

  .select-menu li:hover,
  .select-menu li[aria-selected="true"] {
    background: rgba(230,179,106,0.15);
    color: var(--color-champagne-gold);
  }

  .submit-btn {
    grid-column: 1 / -1;
    width: 100%;
    min-height: 52px;
    margin-top: 8px;
    border: 0;
    border-radius: 0;
    background: var(--color-champagne-gold);
    color: var(--color-primary);
    cursor: pointer;
    font-family: var(--font-family);
    font-size: 16px;
    font-weight: 800;
    letter-spacing: 0.03em;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .submit-btn:hover {
    background: var(--color-link-hover);
    transform: translateY(-1px);
  }

  /* Contact Info Cards */
  .info-card {
    background: var(--color-white);
    border-radius: var(--border-radius);
    padding: clamp(24px, 4vw, 36px);
    margin-bottom: 24px;
  }

  .info-card h2 {
    margin: 0 0 24px;
    font-size: 20px;
    color: var(--color-primary);
    position: relative;
    padding-bottom: 14px;
  }

  .info-card h2::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 40px;
    height: 3px;
    background: var(--color-champagne-gold);
    border-radius: 2px;
  }

  .info-item {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 16px 0;
  }
.info-icon {
    flex: 0 0 44px;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(230,179,106,0.12);
    border-radius: 8px;
    color: var(--color-champagne-gold);
  }

  .info-icon svg {
    width: 22px;
    height: 22px;
    fill: currentColor;
  }

  .info-body {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .info-label {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(16,32,48,0.45);
  }

  .info-value {
    font-size: 15px;
    color: var(--color-text);
    line-height: 1.4;
    text-decoration: none;
  }

  .info-link {
    color: var(--color-brand-blue);
  }

  .info-link:hover {
    color: var(--color-champagne-gold);
  }

  /* Social Icons */
  .info-social {
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid var(--color-neutral-gray);
  }

  .social-label {
    display: block;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(16,32,48,0.45);
    margin-bottom: 14px;
  }

  .social-icons {
    display: flex;
    gap: 12px;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(11,31,51,0.06);
    color: var(--color-primary);
    transition: background 0.22s ease, color 0.22s ease, transform 0.22s ease;
  }

  .social-icon svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }

  .social-icon:hover {
    background: var(--color-champagne-gold);
    color: var(--color-primary);
    transform: translateY(-2px);
  }

  /* Quick Links */
  .quick-links ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .quick-links li a {
    display: flex;
    align-items: center;
    padding: 10px 0;
    color: var(--color-text);
    text-decoration: none;
    font-size: 15px;
    transition: color 0.2s ease, padding-left 0.2s ease;
  }

  .quick-links li a::before {
    content: "\2192";
    margin-right: 10px;
    color: var(--color-champagne-gold);
    font-size: 14px;
    transition: margin-right 0.2s ease;
  }

  .quick-links li a:hover {
    color: var(--color-champagne-gold);
    padding-left: 4px;
  }
/* Responsive */
  @media (max-width: 1024px) {
    .contact-two-col {
      grid-template-columns: 1fr;
    }

    .contact-info-wrap {
      order: -1;
    }
  }

  @media (max-width: 767px) {
    .contact-page-header {
      padding: 48px 0;
    }

    .contact-main-section {
      padding: 40px 0;
    }

    .form-grid {
      grid-template-columns: 1fr;
    }

    .inquiry-form-box {
      padding: 24px;
    }
  }
</style>

<script is:inline>
  (function () {
    document.querySelectorAll('[data-custom-select]').forEach(function (select) {
      var toggle = select.querySelector('.select-toggle');
      var menu = select.querySelector('.select-menu');
      var hidden = select.querySelector('input[type="hidden"]');
      var label = select.querySelector('[data-selected-label]');

      if (!toggle || !menu || !hidden) return;

      toggle.addEventListener('click', function (e) {
        e.stopPropagation();
        var isOpen = select.classList.contains('is-open');
        document.querySelectorAll('[data-custom-select].is-open').forEach(function (s) {
          s.classList.remove('is-open');
          s.querySelector('.select-toggle')?.setAttribute('aria-expanded', 'false');
        });
        if (!isOpen) {
          select.classList.add('is-open');
          toggle.setAttribute('aria-expanded', 'true');
        }
      });

      menu.querySelectorAll('li').forEach(function (li) {
        li.addEventListener('click', function () {
          var value = li.getAttribute('data-value') || '';
          hidden.value = value;
          if (label) label.textContent = li.textContent || value;
          menu.querySelectorAll('li').forEach(function (l) { l.removeAttribute('aria-selected'); });
          li.setAttribute('aria-selected', 'true');
          select.classList.remove('is-open');
          toggle.setAttribute('aria-expanded', 'false');
        });
      });
    });

    document.addEventListener('click', function () {
      document.querySelectorAll('[data-custom-select].is-open').forEach(function (s) {
        s.classList.remove('is-open');
        s.querySelector('.select-toggle')?.setAttribute('aria-expanded', 'false');
      });
    });
  })();
</script>

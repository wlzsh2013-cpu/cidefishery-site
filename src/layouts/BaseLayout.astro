---

import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import JsonLd from '../components/JsonLd.astro';
import { SITE_CONFIG } from '../content/config/site.config';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    tags?: string[];
  };
  jsonLdType?: 'Organization' | 'WebSite' | 'Article' | 'Product' | 'FAQ' | 'BreadcrumbList';
  jsonLdData?: Record<string, unknown>;
  breadcrumbs?: { name: string; url: string }[];
  showBreadcrumb?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage,
  ogType,
  noindex,
  article,
  jsonLdType = 'Organization',
  jsonLdData = {},
  breadcrumbs,
  showBreadcrumb = false,
} = Astro.props;

---

<!DOCTYPE html>
<html lang={SITE_CONFIG.lang}>
  <head>
    <meta charset="UTF-8" />`n    <base href="/cidefishery-site/" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={SITE_CONFIG.favicon} />

    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogType={ogType}
      noindex={true}
      article={article}
    />

    <JsonLd type={jsonLdType} data={jsonLdData} breadcrumbs={breadcrumbs} />
  </head>

  <body>
    <Navigation />

    {showBreadcrumb && breadcrumbs && breadcrumbs.length > 0 && (
      <div class="container">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <ol>
            <li><a href="/">Home</a></li>
            {breadcrumbs.map((bc, i) => (
              <li>
                <span class="bc-sep">/</span>
                {i === breadcrumbs.length - 1 ? (
                  <span class="bc-current" aria-current="page">{bc.name}</span>
                ) : (
                  <a href={bc.url}>{bc.name}</a>
                )}
              </li>
            ))}
          </ol>
        </nav>
      </div>
    )}

    <main>
      <slot />
    </main>

    <Footer />
  </body>
</html>

<style is:global>
  .breadcrumb {
    padding: 16px 0;
  }
  .breadcrumb ol {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }
  .breadcrumb li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: var(--fs-small);
  }
  .breadcrumb a {
    color: var(--color-text);
    opacity: 0.6;
    text-decoration: none;
  }
  .breadcrumb a:hover {
    color: var(--color-champagne-gold);
    opacity: 1;
  }
  .bc-sep {
    color: var(--color-neutral-gray);
  }
  .bc-current {
    color: var(--color-primary);
  }
</style>



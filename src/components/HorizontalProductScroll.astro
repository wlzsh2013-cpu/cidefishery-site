<section class="gp-cc-section" data-gp-hscroll>
  <div class="gp-cc-sticky">
    <div class="gp-cc-header">
      <h2>Artemia Cysts Products for Aquaculture</h2>
    </div>
    <div class="gp-cc-viewport">
      <div class="gp-cc-track">
        <article class="gp-cc-card">
          <div class="gp-cc-media"><img src="/images/artemia-cysts.avif" alt="Artemia Cysts" width="580" height="320" loading="lazy"></div>
          <div class="gp-cc-content">
            <h3>Artemia Cysts</h3>
            <p>Standard Artemia cysts for shrimp hatcheries, fish fry feeding, crab larvae programs and distributors.</p>
            <div class="gp-cc-link"><a href="/products/artemia-cysts/">View Artemia Cysts <span>&rarr;</span></a></div>
          </div>
        </article>
        <article class="gp-cc-card">
          <div class="gp-cc-media"><img src="/images/premium-artemia-cysts.avif" alt="Premium Artemia Cysts" width="580" height="320" loading="lazy"></div>
          <div class="gp-cc-content">
            <h3>Premium Artemia Cysts</h3>
            <p>Selected premium batches for hatcheries requiring stable performance and careful handling.</p>
            <div class="gp-cc-link"><a href="/products/premium-artemia-cysts/">View Premium Artemia Cysts <span>&rarr;</span></a></div>
          </div>
        </article>
        <article class="gp-cc-card">
          <div class="gp-cc-media"><img src="/images/decapsulated-brine-shrimp-eggs.avif" alt="Decapsulated Brine Shrimp Eggs" width="580" height="320" loading="lazy"></div>
          <div class="gp-cc-content">
            <h3>Decapsulated Brine Shrimp Eggs</h3>
            <p>Decapsulated brine shrimp eggs for fish fry feeding and specialized aquaculture programs.</p>
            <div class="gp-cc-link"><a href="/products/decapsulated-eggs/">View Decapsulated Eggs <span>&rarr;</span></a></div>
          </div>
        </article>
        <article class="gp-cc-card">
          <div class="gp-cc-media"><img src="/images/bulk-artemia-cysts.avif" alt="Bulk Artemia Cysts" width="580" height="320" loading="lazy"></div>
          <div class="gp-cc-content">
            <h3>Bulk Artemia Cysts</h3>
            <p>Bulk Artemia cyst supply for importers, wholesalers, and distributors with export coordination.</p>
            <div class="gp-cc-link"><a href="/products/bulk-artemia-cysts/">View Bulk Artemia Cysts <span>&rarr;</span></a></div>
          </div>
        </article>
      </div>
    </div>
  </div>
</section>

<style>
.gp-cc-section {
  --gp-bg: #F5F8FC;
  --gp-text: #102030;
  --gp-muted: rgba(16,32,48,0.65);
  --gp-card-bg: #fff;
  --gp-border: rgba(11,31,51,0.08);
  --gp-radius: 12px;
  --gp-gap: clamp(22px,3vw,36px);
  --gp-card-width: min(68vw,580px);
  --gp-side-padding: max(24px,calc((100vw - 1200px)/2 + 24px));
  position: relative;
  background: var(--gp-bg);
  color: var(--gp-text);
  overflow: visible;
  font-family: var(--font-family);
}
.gp-cc-sticky {
  position: sticky;
  top: 0;
  height: 120vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: clamp(78px, calc(5vh + 50px), 98px);
  padding: clamp(48px,7vh,80px) 0 clamp(98px,7vh,130px);
  box-sizing: border-box;
}
.gp-cc-header { padding: 0 var(--gp-side-padding); }
.gp-cc-header h2 { margin: 0; max-width: 960px; font-size: clamp(36px,5vw,48px); line-height: 1.05; font-weight: 700; color: var(--color-h2); }
.gp-cc-viewport { width: 100%; overflow: visible; }
.gp-cc-track { display: flex; gap: var(--gp-gap); padding: 0 var(--gp-side-padding); will-change: transform; transform: translate3d(0,0,0); }
.gp-cc-card { flex: 0 0 var(--gp-card-width); min-height: clamp(460px,54vh,580px); background: var(--gp-card-bg); border: 1px solid var(--gp-border); border-radius: var(--gp-radius); overflow: hidden; box-shadow: 0 8px 32px rgba(11,31,51,0.06); display: flex; flex-direction: column; transition: box-shadow 0.3s; }
.gp-cc-card:hover { box-shadow: 0 16px 48px rgba(11,31,51,0.12); }
.gp-cc-media { position: relative; background: linear-gradient(135deg,rgba(11,31,51,0.04),rgba(30,95,168,0.03)),#e9eaf0; overflow: hidden; }
.gp-cc-media img { width: 100%; height: 100%; object-fit: contain; display: block; }
.gp-cc-placeholder { width: 100%; height: 100%; display: grid; place-items: center; color: rgba(11,31,51,0.28); font-size: clamp(20px,3vw,40px); font-weight: 700; }
.gp-cc-content { padding: clamp(22px,2.5vw,32px); display: flex; flex-direction: column; flex: 1; }
.gp-cc-content h3 { margin: 0 0 10px; font-size: clamp(24px,2.5vw,32px); line-height: 1.15; font-weight: 700; }
.gp-cc-content p { margin: 0; max-width: 520px; font-size: clamp(15px,1.2vw,17px); line-height: 1.55; color: var(--gp-muted); flex: 1; }
.gp-cc-link { margin-top: 20px; }
.gp-cc-link a { display: inline-flex; align-items: center; gap: 6px; font-size: 14px; font-weight: 600; color: #E6B36A; text-decoration: none; transition: gap 0.2s; }
.gp-cc-link a:hover { gap: 10px; }
@media (max-width: 1024px) {
  .gp-cc-section { height: auto !important; }
  .gp-cc-sticky { position: relative; height: auto; overflow: visible; padding: 64px 0; }
  .gp-cc-header h2 { font-size: clamp(32px,7vw,40px); color: var(--color-h2); }
  .gp-cc-track { transform: none !important; flex-direction: column; }
  .gp-cc-card { flex: none; width: auto; min-height: auto; }
}
</style>
<script is:inline src="/hscroll.js"></script>

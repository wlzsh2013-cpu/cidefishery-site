---
import Button from './Button.astro';
import Icon from './Icon.astro';

export interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
}

const { title, description, href, icon } = Astro.props;
---

<article class="app-card">
  <Icon name={icon} label={`${title} application icon`} desc={description} className="app-icon" />
  <h3><a href={href}>{title}</a></h3>
  <p>{description}</p>
  <Button href={href} variant="text" size="sm">Learn More &rarr;</Button>
</article>

<style>
  .app-card {
    background: var(--color-white);
    border: 1px solid var(--color-neutral-gray);
    border-radius: var(--border-radius);
    padding: 32px 24px;
    text-align: center;
    transition: box-shadow 0.3s ease;
  }
  .app-card:hover {
    box-shadow: 0 8px 24px rgba(11, 31, 51, 0.08);
  }
  .app-icon {
    width: 76px;
    height: 76px;
    display: inline-flex;
    margin-bottom: 16px;
  }
  .app-card h3 {
    margin-bottom: 8px;
  }
  .app-card h3 a {
    color: var(--color-h2-h3-h4);
  }
  .app-card h3 a:hover {
    color: var(--color-champagne-gold);
  }
  .app-card p {
    font-size: var(--fs-small);
    color: var(--color-text);
    opacity: 0.8;
    margin-bottom: 12px;
  }
</style>

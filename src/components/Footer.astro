<style>
.cf-footer {
  width: 100%;
  font-family: var(--font-family);
  overflow: hidden;
}

.cf-footer,
.cf-footer * {
  box-sizing: border-box;
}

.cf-footer-main {
  padding: clamp(60px, 7vw, 110px) 0;
  background:
    radial-gradient(circle at 12% 16%, rgba(30,95,168,0.18), transparent 32%),
    radial-gradient(circle at 88% 88%, rgba(53,183,216,0.10), transparent 36%),
    linear-gradient(135deg, #0B1F33, #061524);
}

.cf-footer-container {
  width: 90%;
  max-width: 1320px;
  margin: 0 auto;
}

.cf-footer-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1.5fr;
  gap: clamp(34px, 5vw, 90px);
}

.cf-footer-col h3 {
  margin: 0 0 24px;
  font-size: clamp(15px, 1vw, 17px);
  line-height: 1.2;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #ffffff;
}

.cf-footer-col ul {
  list-style: none;
  margin: 0;
  padding: 0;
}

.cf-footer-col li {
  margin: 0 0 14px;
  color: rgba(255, 255, 255, 0.64);
  font-size: clamp(15px, 1vw, 17px);
  line-height: 1.45;
}

.cf-footer-col a {
  color: rgba(255, 255, 255, 0.64);
  text-decoration: none;
  transition: color 0.22s ease;
}

.cf-footer-col a:hover {
  color: #E6B36A;
}

.cf-footer-contact li {
  display: flex;
  align-items: flex-start;
  gap: 12px;
}

.cf-footer-icon {
  flex: 0 0 24px;
  width: 24px;
  height: 24px;
  color: #E6B36A;
  opacity: 0.85;
}

.cf-footer-icon svg {
  width: 100%;
  height: 100%;
  display: block;
  fill: currentColor;
}


.cf-footer-social {
  display: flex;
  gap: 16px;
  margin-top: 24px;
}

.cf-social-link {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.10);
  color: rgba(255, 255, 255, 0.70);
  transition: background 0.22s ease, color 0.22s ease, transform 0.22s ease;
}

.cf-social-link svg {
  width: 20px;
  height: 20px;
  fill: currentColor;
}

.cf-social-link:hover {
  background: #E6B36A;
  color: #0B1F33;
  transform: translateY(-2px);
}
.cf-footer-bottom {
  border-top: 1px solid rgba(255, 255, 255, 0.10);
  background: #061524;
}

.cf-footer-bottom-inner {
  min-height: 74px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  padding: 18px 0;
}

.cf-footer-bottom p {
  margin: 0;
  font-size: 15px;
  line-height: 1.4;
  font-weight: 600;
  color: #f9fafb;
}

.cf-back-top {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 0;
  padding: 0;
  background: transparent;
  color: #f9fafb;
  font-size: 14px;
  line-height: 1;
  font-weight: 800;
  letter-spacing: 0.04em;
  cursor: pointer;
  transition: color 0.22s ease, transform 0.22s ease;
}

.cf-back-top:hover {
  color: #E6B36A;
  transform: translateY(-2px);
}

.cf-footer-brand-wrap {
  background: #F5F8FC;
  padding: clamp(34px, 5vw, 76px) 0;
}

.cf-footer-brand-img {
  width: 90%;
  max-width: 1760px;
  height: auto;
  display: block;
  margin: 0 auto;
}

@media (max-width: 1024px) {
  .cf-footer-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 767px) {
  .cf-footer-container {
    width: 90%;
  }

  .cf-footer-grid {
    grid-template-columns: 1fr;
    gap: 36px;
  }

  .cf-footer-bottom-inner {
    flex-direction: column;
    align-items: flex-start;
  }
}
</style>

<script is:inline>
(function () {
  var btn = document.querySelector("[data-cf-back-top]");
  if (btn) {
    btn.addEventListener("click", function () {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  }
})();
</script>
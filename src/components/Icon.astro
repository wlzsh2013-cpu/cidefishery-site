---
interface Props {
  name: string;
  label: string;
  desc?: string;
  className?: string;
}

const { name, label, desc = '', className = '' } = Astro.props;
const safeName = name.replace(/[^a-z0-9-]/gi, '');
const titleId = `cf-icon-title-${safeName}`;
const descId = `cf-icon-desc-${safeName}`;
const iconClass = ['cf-icon', className].filter(Boolean).join(' ');
const capabilityIcons = [
  'processing',
  'cold-storage',
  'quality-control',
  'packaging',
  'raw-material-classification',
  'automated-washing-screening',
  'controlled-fluid-bed-drying',
  'hermetic-packing-export-prep',
  'origin-batch-traceability',
  'advanced-refining-control',
  'storage-inventory-log',
  'hermetic-integrity-verification',
  'china-raw-material-network',
  'international-cooperation',
  'uzbekistan-development',
  'global-export-footprint',
];
const isCapabilityIcon = capabilityIcons.includes(name);
const svgViewBox = isCapabilityIcon ? '0 0 58 58' : '0 0 96 96';
const svgSize = isCapabilityIcon ? 58 : 96;

const palette: Record<string, string> = {
  processing: '#497EB8',
  'cold-storage': '#5BC4DF',
  packaging: '#3A4B5B',
  'quality-control': '#E9C187',
  'raw-material-classification': '#497EB8',
  'automated-washing-screening': '#5BC4DF',
  'controlled-fluid-bed-drying': '#E9C187',
  'hermetic-packing-export-prep': '#3A4B5B',
  'origin-batch-traceability': '#497EB8',
  'advanced-refining-control': '#5BC4DF',
  'storage-inventory-log': '#E9C187',
  'hermetic-integrity-verification': '#3A4B5B',
  'china-raw-material-network': '#497EB8',
  'international-cooperation': '#5BC4DF',
  'uzbekistan-development': '#E9C187',
  'global-export-footprint': '#3A4B5B',
  'global-supply': '#1E5FA8',
  'shrimp-hatchery': '#E6B36A',
  'fish-fry': '#35B7D8',
  'crab-larvae': '#0B1F33',
  'artemia-cysts': '#1E5FA8',
  'guide-shrimp-hatchery': '#497EB8',
  'guide-fish-fry': '#497EB8',
  'guide-crab-nursery': '#497EB8',
  'guide-global-distribution': '#497EB8',
};

const color = palette[name] || '#1E5FA8';
---

<span class={iconClass} role="img" aria-labelledby={`${titleId} ${descId}`}>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox={svgViewBox} width={svgSize} height={svgSize} fill="none">
    <title id={titleId}>{label}</title>
    <desc id={descId}>{desc || `${label} icon for CIDE FISHERY aquaculture supply website`}</desc>
    <circle cx={isCapabilityIcon ? 29 : 48} cy={isCapabilityIcon ? 29 : 48} r={isCapabilityIcon ? 29 : 36} fill={color} fill-opacity={isCapabilityIcon ? undefined : '0.8'} />

    {name === 'processing' && (
      <g transform="scale(0.6041666667)">

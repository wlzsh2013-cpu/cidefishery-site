<style>
  .cf-icon {
    display: inline-flex;
    width: 56px;
    height: 56px;
    flex: 0 0 auto;
  }
  .cf-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  .cf-stroke {
    stroke: #ffffff;
    stroke-width: 3.4;
    stroke-linecap: round;
    stroke-linejoin: round;
    fill: none;
  }
  .cf-thin {
    stroke-width: 2.5;
  }
  .cf-fill {
    fill: #ffffff;
  }
</style>
